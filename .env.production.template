# =============================================================================
# StaySuite HospitalityOS — Production Environment Configuration
# =============================================================================
# This is the MASTER production env template. The deploy script
# (production-install/deploy-rocky10-pgsql_fr.sh) copies this file to .env
# and replaces all __PLACEHOLDER__ markers with real values during installation.
#
# DO NOT put real secrets in this file — it is committed to git.
# The deploy script generates cryptographically random secrets at install time.
#
# Placeholders replaced at deploy time (Step 8):
#   __DBPASS__          -> PostgreSQL password (from --db-password, default: Staysuite2025)
#   __APP_URL__         -> http://<server-ip>:3000 (from --app-url or auto-detect)
#   __APP_DIR__         -> Installation directory (from --app-dir, default: /opt/staysuite)
#   __NEXTAUTH_SECRET__ -> Random 64-char hex (auto-generated per install)
#   __CRON_SECRET__     -> Random 48-char hex (auto-generated per install)
#   __ENCRYPTION_KEY__  -> Random 64-char base64 (auto-generated per install)
#   __SERVICE_SECRET__  -> Random 48-char hex (auto-generated per install)
#   __PG_MAJOR__        -> Detected PostgreSQL major version (16 or 17)
#
# IMPORTANT: After deploy, this file is preserved as .env.production.template
# for reference. The actual runtime config is in .env (gitignored).
# =============================================================================

# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SANDBOX_MODE=false
LOG_LEVEL=info

# ─── Application URLs ─────────────────────────────────────────────────────
# All four MUST match. Deploy script auto-detects the primary IP.
NEXT_PUBLIC_APP_URL=__APP_URL__
APP_URL=__APP_URL__
NEXTAUTH_URL=__APP_URL__
CORS_ORIGIN=__APP_URL__

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://staysuite:__DBPASS__@127.0.0.1:5432/staysuite
DATABASE_URL_UNPOOLED=postgresql://staysuite:__DBPASS__@127.0.0.1:5432/staysuite

# ─── Authentication & Security ────────────────────────────────────────────
NEXTAUTH_SECRET=__NEXTAUTH_SECRET__
CRON_SECRET=__CRON_SECRET__
ENCRYPTION_KEY=__ENCRYPTION_KEY__
SERVICE_AUTH_SECRET=__SERVICE_SECRET__

# ─── Demo Mode ────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEMO_MODE=false

# ─── WebSocket / Realtime ────────────────────────────────────────────────
WS_PORT=3001
REALTIME_SERVICE_URL=http://127.0.0.1:3003

# ─── FreeRADIUS / WiFi ────────────────────────────────────────────────────
RADIUS_HOST=127.0.0.1
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_SECRET=localkey
RADIUS_SERVICE_URL=http://127.0.0.1:3010
RADIUS_SERVICE_AUTH_SECRET=__SERVICE_SECRET__
RADIUS_DATABASE_URL=
FREERADIUS_PORT=3010
FREERADIUS_HOME=/etc/raddb
FREERADIUS_SANDBOX_HOME=
RADDB_PATH=/etc/raddb
RADIUS_CONFIG_PATH=/etc/raddb
RADIUSD_BIN=radiusd
RADIUSD_EXECUTABLE=/usr/sbin/radiusd
RADIUSD_PID_FILE=/run/radiusd/radiusd.pid
RADIUSD_LOG_DIR=/var/log/radiusd
RADIUS_DICT_DIR=/usr/share/freeradius
RADIUS_LIB_DIR=/usr/lib64/freeradius
RADCLIENT_BIN=/usr/bin/radclient
RADTEST_BIN=/usr/bin/radtest
SYSTEMD_SERVICE_NAME=radiusd

# ─── PostgreSQL Paths ─────────────────────────────────────────────────────
PG_BIN=/usr/pgsql-__PG_MAJOR__/bin
PG_DATA=/var/lib/pgsql/__PG_MAJOR__/data
PG_PORT=5432

# ─── Network Services ─────────────────────────────────────────────────────
NFTABLES_SERVICE_URL=http://127.0.0.1:3013
NFTABLES_DB_URL=postgresql://staysuite:__DBPASS__@127.0.0.1:5432/staysuite
DHCP_SERVICE_URL=http://127.0.0.1:3011
DNS_SERVICE_URL=http://127.0.0.1:3012

# ─── Network Utilities ────────────────────────────────────────────────────
ULOGD_DIR=/var/log/ulogd2
DHCP_LEASE_FILE=/var/lib/dnsmasq/dnsmasq.leases
DNSMASQ_BIN=/usr/sbin/dnsmasq
DNSMASQ_CONF_DIR=/etc/dnsmasq.d
DNSMASQ_LEASES_FILE=/var/lib/dnsmasq/dnsmasq.leases
DNSMASQ_PID_FILE=/run/dnsmasq/dnsmasq.pid
DNSMASQ_RESOLV_CONF=/etc/resolv.conf
CONNTRACK_BIN=/usr/sbin/conntrack
SPEEDTEST_BIN=/usr/bin/speedtest

# ─── Network Config Paths ─────────────────────────────────────────────────
NETWORK_INTERFACES_FILE=/etc/network/interfaces
NETWORK_SCRIPTS_DIR=/etc/network
STAYSUITE_SCRIPTS_DIR=__APP_DIR__/scripts/network
RESTRICTED_NETWORK_PATH=/etc/restrictednetwork
STAYSUITE_NAT_ACTION=masq

# ─── ZTNA / Room VLAN Scripts ────────────────────────────────────────────
ZTNA_SCRIPT_PATH=/usr/local/scripts/nftables/ztna-apply.sh
ROOM_VLAN_SCRIPT_PATH=/usr/local/scripts/nftables/room-vlan-apply.sh

# ─── Session Engine ───────────────────────────────────────────────────────
SE_LOG_TIMEZONE=Asia/Kolkata
SNI_LOG_FILE=/var/log/ulogd2/sni.json
SNI_LOG_FORMAT=auto
DNS_LOG_FILE=/var/log/dns-queries.log
PCAP_CAPTURE_DIR=/tmp/staysuite-captures

# ─── ClickHouse (IPDR Analytics) ──────────────────────────────────────────
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── Captive Portal ───────────────────────────────────────────────────────
PORTAL_PORT=3000
PORTAL_SCHEME=http
REDIRECT_PATH=/connect
CLIENT_TIMEOUT_MS=5000
REDIRECT_COOLDOWN_MS=3000
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=10000
WHITELIST_CHECK_INTERVAL_MS=30000

# ─── Conntrack Bridge / IPDR ──────────────────────────────────────────────
GUEST_CACHE_TTL=60000
GUEST_CACHE_MAX=5000
GUEST_ENRICHER_SILENT=true

# ─── Bandwidth / RRD ─────────────────────────────────────────────────────
RRD_BIN_PATH=__APP_DIR__/rrdtool/bin/rrdtool
RRD_LIB_PATH=__APP_DIR__/rrdtool/lib
RRD_DATA_PATH=__APP_DIR__/data/rrd

# ─── File Uploads ─────────────────────────────────────────────────────────
UPLOAD_DIR=__APP_DIR__/uploads

# ─── IP Whitelist (comma-separated, leave empty for no restriction) ───────
# IP_WHITELIST=10.0.0.0/8,192.168.0.0/16

# ─── E2Guardian (Web Content Filter) ──────────────────────────────────────
# E2GUARDIAN_CONF_DIR=/etc/e2guardian
# E2GUARDIAN_LIST_DIR=/etc/e2guardian/lists
# E2GUARDIAN_STATUS_FILE=/run/e2guardian/e2guardian.status

# ─── Weather Widget (client-side) ─────────────────────────────────────────
# NEXT_PUBLIC_OPENWEATHER_API_KEY=your-openweather-api-key
# NEXT_PUBLIC_DEFAULT_CITY=Mumbai

# ─── GSTN (Indian GST Compliance) ────────────────────────────────────────
# GSTN_ENV=sandbox
# GSTN_CLIENT_ID=your-gstn-client-id
# GSTN_CLIENT_SECRET=your-gstn-client-secret
# GSTN_IP_ADDRESS=your-server-ip
# GSTN_SIGNING_SECRET=your-gstn-signing-secret

# ─── DGD Scripts ──────────────────────────────────────────────────────────
# DGD_DB_HOST=localhost
# DGD_DB_PORT=5432
# DGD_DB_NAME=staysuite
# DGD_DB_USER=staysuite
# DGD_DB_PASS=__DBPASS__

