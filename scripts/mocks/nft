#!/bin/bash
# Mock nft command for sandbox testing
# Logs all invocations and simulates responses

MOCK_LOG="/tmp/nft_mock.log"
MOCK_STATE_DIR="/tmp/nft_mock_state"
mkdir -p "$MOCK_STATE_DIR"

# Log every invocation
echo "$(date '+%H:%M:%S') nft $*" >> "$MOCK_LOG"

# Parse command and simulate appropriate responses
CMD="$1"
shift

case "$CMD" in
    # nft add element inet mangle loggedinusers { 1.2.3.4 }
    add)
        case "$2" in
            element)
                # Extract: nft add element <table> <set> { <value> }
                TABLE="$3"; SET="$4"; shift 4
                # Value is everything inside { }
                VALUE=$(echo "$*" | sed 's/[{}]//g' | xargs)
                STATE_FILE="$MOCK_STATE_DIR/${TABLE}_${SET}"
                echo "$VALUE" >> "$STATE_FILE"
                echo "[MOCK nft] Added $VALUE to $TABLE/$SET"
                ;;
            rule)
                # Log rule addition - just record it
                echo "[MOCK nft] add rule: $*" >> "$MOCK_LOG"
                echo "[MOCK nft] Rule added (simulated)"
                ;;
            set)
                # nft add set ... (skip)
                echo "[MOCK nft] Set created (simulated)"
                ;;
            table)
                echo "[MOCK nft] Table created (simulated)"
                ;;
            chain)
                echo "[MOCK nft] Chain created (simulated)"
                ;;
            *)
                echo "[MOCK nft] add $* (simulated)"
                ;;
        esac
        ;;

    # nft insert rule ...
    insert)
        # Same as add rule
        echo "[MOCK nft] insert rule: $*" >> "$MOCK_LOG"
        echo "[MOCK nft] Rule inserted (simulated)"
        ;;

    # nft delete element inet mangle loggedinusers { 1.2.3.4 }
    delete)
        case "$2" in
            element)
                TABLE="$3"; SET="$4"; shift 4
                VALUE=$(echo "$*" | sed 's/[{}]//g' | xargs)
                STATE_FILE="$MOCK_STATE_DIR/${TABLE}_${SET}"
                if [[ -f "$STATE_FILE" ]]; then
                    grep -v "^${VALUE}$" "$STATE_FILE" > "${STATE_FILE}.tmp" 2>/dev/null
                    mv "${STATE_FILE}.tmp" "$STATE_FILE" 2>/dev/null
                    echo "[MOCK nft] Deleted $VALUE from $TABLE/$SET"
                else
                    echo "[MOCK nft] $VALUE not found in $TABLE/$SET (already deleted)" >&2
                fi
                ;;
            rule)
                echo "[MOCK nft] delete rule: $*" >> "$MOCK_LOG"
                echo "[MOCK nft] Rule deleted (simulated)"
                ;;
            *)
                echo "[MOCK nft] delete $* (simulated)"
                ;;
        esac
        ;;

    # nft get element inet mangle loggedinusers { 1.2.3.4 }
    get)
        case "$2" in
            element)
                TABLE="$3"; SET="$4"; shift 4
                VALUE=$(echo "$*" | sed 's/[{}]//g' | xargs)
                STATE_FILE="$MOCK_STATE_DIR/${TABLE}_${SET}"
                if [[ -f "$STATE_FILE" ]] && grep -qx "^${VALUE}$" "$STATE_FILE"; then
                    echo "[MOCK nft] Element exists: $TABLE/$SET {$VALUE}"
                    exit 0
                else
                    echo "[MOCK nft] Element not found: $TABLE/$SET {$VALUE}" >&2
                    exit 1
                fi
                ;;
        esac
        ;;

    # nft list elements inet mangle loggedinusers
    list)
        case "$2" in
            elements)
                TABLE="$3"; SET="$4"
                STATE_FILE="$MOCK_STATE_DIR/${TABLE}_${SET}"
                if [[ -f "$STATE_FILE" ]] && [[ -s "$STATE_FILE" ]]; then
                    echo "{ $(cat "$STATE_FILE" | tr '\n' ',' | sed 's/,$//') }"
                else
                    echo "{ }"
                fi
                ;;
            set)
                echo "table $3 {"
                echo "  set $4 {"
                echo "    type ipv4_addr"
                echo "  }"
                echo "}"
                ;;
            sets)
                echo "set inet mangle loggedinusers"
                echo "set inet mangle loggedinuserssnatip"
                ;;
            chain)
                # nft -a list chain ... (returns chain rules with handles)
                echo "[MOCK nft] list chain (simulated - empty)"
                ;;
            table)
                echo "table $3 {"
                echo "  chain prerouting { ... }"
                echo "  chain postrouting { ... }"
                echo "  chain input { ... }"
                echo "}"
                ;;
            *)
                echo "[MOCK nft] list $* (simulated)"
                ;;
        esac
        ;;

    flush)
        echo "[MOCK nft] flush $* (simulated)"
        ;;

    *)
        echo "[MOCK nft] Unknown command: $CMD $*" >> "$MOCK_LOG"
        echo "[MOCK nft] Command: $CMD $* (simulated)"
        ;;
esac

exit 0
