# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env.local
.env.production
!.env

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
# PostgreSQL runtime logs (data stays in repo, logs don't)
pgsql-runtime/pgsql.log
pgsql-runtime/data/log/

# FreeRADIUS runtime logs (binaries/configs stay, logs don't)
freeradius-install/var/log/radiusd/*.log

# logs directory
/logs/

dev.log
dev.out.log
test
prompt
server.log
# Skills directory
/skills/custom.db

# RRD data files (tracked structure, not runtime data)
data/rrd/users/*.rrd
data/rrd/interfaces/*.rrd
data/rrd/pools/*.rrd
data/rrd/isp/*.rrd
data/rrd/aggregate/*.rrd
!data/rrd/.gitkeep
# RRD cron state file
data/rrd/state/counter-state.json

# PostgreSQL runtime data (tracked structure, not runtime data)
pgsql-runtime/data/

# FreeRADIUS dependencies and runtime
freeradius-deps/
freeradius/

# E2E test files
src/lib/wifi/services/test-e2e-credentials.ts
