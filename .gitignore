# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# all log files
*.log
# freeradius module configs: detail.log is a raddb module, not a log
!freeradius-install/etc/raddb/mods-available/detail.log
!freeradius-install/etc/raddb/mods-enabled/detail.log
pgsql-logfile

# env files
.env
.env.local
.env.production

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
# PostgreSQL runtime logs (data stays in repo, logs don't)
pgsql-runtime/pgsql.log
pgsql-runtime/data/log/

# FreeRADIUS runtime logs (binaries/configs stay, logs don't)
freeradius-install/var/log/
**/freeradius-install/var/log/

# logs directory
/logs/

test
prompt
# Skills directory
# SQLite database files (production uses PostgreSQL only)
*.db
*.db-shm
*.db-wal
/skills/custom.db

# RRD data files (tracked structure, not runtime data)
data/rrd/users/*.rrd
data/rrd/interfaces/*.rrd
data/rrd/pools/*.rrd
data/rrd/isp/*.rrd
data/rrd/aggregate/*.rrd
data/rrd/system/*.rrd
!data/rrd/.gitkeep
# RRD cron state file
data/rrd/state/counter-state.json

# PostgreSQL runtime data (tracked structure, not runtime data)
pgsql-runtime/data/

# PostgreSQL data directory (binary runtime data, never track)
pgsql-data/

# FreeRADIUS dependencies and runtime
freeradius-deps/
freeradius/

# E2E test files
src/lib/wifi/services/test-e2e-credentials.ts
# Sandbox environment (generated files, QA artifacts, agent working dir)
download/
agent-ctx/

# nftables service generated data (JSON persistence in simulation mode)
mini-services/nftables-service/data/

# Compiled tools and source tarballs (too large for Git, compiled locally)
tools/install/
tools/src/
tools/clickhouse/install/
tools/clickhouse.tgz
tools/*.tgz
/core
# e2guardian: track configs and lists, exclude runtime logs and sensitive private keys
data/e2guardian/logs/
data/e2guardian/private/


# DB backups (binary restore files) — keep marked backups tracked
# db-backup/*.dump

# Worklog
worklog.md
worklog-pms-fixes.md
worklog_append.txt

# Runtime artifacts (pids, temp files)
dev.pid
index
test-w.txt

# StaySuite runtime data & logs
.staysuite/
