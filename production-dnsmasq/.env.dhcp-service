# DHCP Service — Dev Environment
# Points config output to production-dnsmasq directory
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/staysuite
PROJECT_ROOT=/home/z/my-project
DNSMASQ_BIN=/home/z/my-project/production-dnsmasq/src/dnsmasq
DNSMASQ_CONF_DIR=/home/z/my-project/dhcp-local
DNSMASQ_LEASES=/home/z/my-project/production-dnsmasq/leases/dnsmasq.leases
