# StaySuite: LDAP module for enterprise AAA integration
# This module connects FreeRADIUS to OpenLDAP/Active Directory for
# enterprise user authentication (LDAP Bind as user).
#
# Feature flag: Only active when ldapRadiusEnabled = true per property
# When disabled, this module is NOT symlinked in mods-enabled/

ldap {
        # LDAP server URI (local OpenLDAP on non-privileged port)
        server = '127.0.0.1'
        port = 3890

        # Identity for LDAP searches (bind DN for lookups)
        # This account needs read access to the LDAP tree
        identity = 'cn=admin,dc=staysuite,dc=local'
        password = 'Admin@123'

        # Base DN for all operations
        base_dn = 'dc=staysuite,dc=local'

        # LDAPv3
        ldap_version = 3

        # TLS - disabled for local testing, enable for production
        # tls {
        #     start_tls = yes
        #     require_cert = 'demand'
        #     ca_file = ${certdir}/ca.pem
        #     cert_file = ${certdir}/client.pem
        #     key_file = ${certdir}/client.key
        # }

        # ── User configuration ──
        # How to look up users in LDAP
        user {
                # Where to search
                base_dn = "${..base_dn}"

                # Filter: match by uid attribute
                filter = "(uid=%{%{Stripped-User-Name}:-%{User-Name}})"

                # Search scope: subtree (search under base_dn and all sub-OUs)
                scope = 'sub'

                # Access control: allow positive matches
                access_positive = yes

                sasl {
                }
        }

        # Where to find the password attribute for PAP auth
        password_attribute = 'userPassword'

        # Mapping LDAP attributes to RADIUS attributes
        update {
                # Map LDAP userPassword to RADIUS control for PAP authentication
                # This tells the pap module what password to compare against
                control:Password-With-Header += 'userPassword'

                # Map sambaNTPassword for MS-CHAPv2 authentication
                # When this is set, the mschap module can do NT hash comparison
                # without needing to call ntlm_auth
                control:NT-Password += 'sambaNTPassword'
        }

        # ── Group configuration ──
        group {
                # Where to search for groups
                base_dn = "${..base_dn}"

                # Group filter: posixGroup objects
                filter = "(|(memberUid=%{%{Stripped-User-Name}:-%{User-Name}})(member=%{User-DN}))"

                # Search scope
                scope = 'sub'

                # Group name attribute
                name_attribute = 'cn'

                cacheable_name = no
                cacheable_dn = no
                allow_dangling_group_ref = no
        }

        # Group membership checking attribute
        groupname_attribute = 'cn'

        # ── Client configuration (for LDAP-based RADIUS client lookups) ──
        client {
                base_dn = "${..base_dn}"
                filter = '(objectClass=radiusClient)'
                scope = 'sub'
        }

        # Connection pool settings
        pool {
                start = 1
                min = 1
                max = 5
                spare = 3
                uses = 0
                lifetime = 0
                idle_timeout = 60
                connect_timeout = 3.0

                # Retry on connection failure
                retries = 3

                # Delay between retries
                retry_delay = 1
        }

        # Keep-alive — send periodic LDAP pings
        keepalive {
                # Idle time before sending keepalive (seconds)
                idle = 60

                # Number of probes
                probes = 3

                # Interval between probes
                interval = 3
        }

        # Timeout for LDAP operations
        timeout = 10
}
