# =============================================================================
# StaySuite HospitalityOS - Production Environment Configuration
# =============================================================================
# Copy this file to your production server at /opt/staysuite/.env
# IMPORTANT: Change all passwords and secrets before deploying!
# =============================================================================

# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Application URLs ─────────────────────────────────────────────────────
# Public URL that users/guests access (change to your domain)
NEXT_PUBLIC_APP_URL=http://10.121.18.163:3000
APP_URL=http://10.121.18.163:3000
NEXTAUTH_URL=http://10.121.18.163:3000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://staysuite:Staysuite2025@127.0.0.1:5432/staysuite

# ─── Authentication & Security ────────────────────────────────────────────
# CRITICAL: Generate a strong random secret (openssl rand -base64 32)
NEXTAUTH_SECRET=staysuite-nextauth-secret-change-me-2025
# CRITICAL: Used to authenticate cron/webhook endpoints
CRON_SECRET=staysuite-cron-secret-2025
# CRITICAL: Used for encrypting sensitive data at rest (32 chars min)
ENCRYPTION_KEY=staysuite-encryption-key-change-me!
# Internal service-to-service auth
SERVICE_AUTH_SECRET=staysuite-service-auth-secret-2025

# ─── Demo Mode ────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEMO_MODE=false

# ─── ClickHouse (IPDR Analytics) ──────────────────────────────────────────
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── FreeRADIUS / WiFi ────────────────────────────────────────────────────
RADIUS_HOST=127.0.0.1
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_SECRET=staysuite-radius-secret
RADIUS_SERVICE_URL=http://127.0.0.1:3010
RADIUS_SERVICE_AUTH_SECRET=staysuite-radius-service-secret-2025
FREERADIUS_PORT=3004
FREERADIUS_HOME=/etc/freeradius
RADIUS_CONFIG_PATH=/etc/raddb
RADIUS_DATABASE_URL=

# ─── Network Services ─────────────────────────────────────────────────────
NFTABLES_SERVICE_URL=http://127.0.0.1:3013
DHCP_SERVICE_URL=http://localhost:3011
DNS_SERVICE_URL=http://localhost:3012
ULOGD_DIR=/var/log/ulogd2
DHCP_LEASE_FILE=/var/lib/dnsmasq/dnsmasq.leases

# ─── Captive Portal ───────────────────────────────────────────────────────
PORTAL_PORT=3000
PORTAL_SCHEME=http
REDIRECT_PATH=/connect

# ─── Email / SMTP ─────────────────────────────────────────────────────────
# Configure these to enable email delivery
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_SECURE=true
# EMAIL_FROM="StaySuite" <noreply@your-domain.com>
# SMTP_FROM="StaySuite" <noreply@your-domain.com>

# ─── SMS (Twilio) ────────────────────────────────────────────────────────
# Configure these to enable SMS delivery
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+91XXXXXXXXXX
# SMS_DEFAULT_COUNTRY_CODE=IN

# ─── AI / LLM ─────────────────────────────────────────────────────────────
# AI_PROVIDER=openai
# AI_API_KEY=sk-your-openai-api-key
# AI_MODEL=gpt-4o-mini

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────
# WHATSAPP_ACCESS_TOKEN=your-meta-access-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
# WHATSAPP_APP_SECRET=your-meta-app-secret
# WHATSAPP_PHONE_NUMBER=+91XXXXXXXXXX

# ─── Payments (Stripe) ───────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret
# STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ─── Payments (PayPal) ───────────────────────────────────────────────────
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# PAYPAL_MODE=live

# ─── Google OAuth ─────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── S3 Storage ──────────────────────────────────────────────────────────
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=your-bucket-name
# S3_REGION=ap-south-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_PUBLIC_URL=https://your-bucket-name.s3.amazonaws.com

# ─── Firebase / Push Notifications ───────────────────────────────────────
# FCM_SENDER_ID=your-fcm-sender-id
# FCM_SERVER_KEY=your-fcm-server-key

# ─── Redis (Optional - for caching) ─────────────────────────────────────
# REDIS_URL=redis://127.0.0.1:6379

# ─── WebSocket / Realtime ────────────────────────────────────────────────
WS_PORT=3001
REALTIME_SERVICE_URL=http://127.0.0.1:3003
CORS_ORIGIN=http://10.121.18.163:3000

# ─── Bandwidth / RRD ─────────────────────────────────────────────────────
RRD_BIN_PATH=/opt/staysuite/rrdtool/bin/rrdtool
RRD_LIB_PATH=/opt/staysuite/rrdtool/lib
RRD_DATA_PATH=/opt/staysuite/data/rrd

# ─── IPDR Pipeline ────────────────────────────────────────────────────────
CONNTRACK_BIN=/usr/sbin/conntrack
SNI_LOG_FILE=/var/log/ulogd2/sni.json
DNS_LOG_FILE=/var/log/dns-queries.log
SE_LOG_TIMEZONE=Asia/Kolkata

# ─── Revenue / Channel Management ─────────────────────────────────────────
# BOOKING_API_KEY=your-booking-com-api-key
# BOOKING_API_SECRET=your-booking-com-api-secret
# EXPEDIA_API_KEY=your-expedia-api-key

# ─── NAT ─────────────────────────────────────────────────────────────────
STAYSUITE_NAT_ACTION=masq

# ─── IP Whitelist (comma-separated, leave empty for no restriction) ──────
# IP_WHITELIST=10.0.0.0/8,192.168.0.0/16

# ─── Session Engine ───────────────────────────────────────────────────────
SE_LOG_TIMEZONE=Asia/Kolkata
