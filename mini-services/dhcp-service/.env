DATABASE_URL=postgresql://staysuite:Staysuite2025@127.0.0.1:5432/staysuite
PROJECT_ROOT=/home/z/my-project
# NOTE: DNSMASQ_CONF_DIR and DNSMASQ_LEASES are only used in sandbox/dev mode
# (when system dnsmasq is NOT installed). On production (Rocky 10 with dnsmasq),
# the service always uses /etc/dnsmasq.d and /var/lib/dnsmasq/dnsmasq.leases.
DNSMASQ_CONF_DIR=/home/z/my-project/dhcp-local
DNSMASQ_LEASES=/tmp/dnsmasq-dhcp.leases
