/// FirewallRule - Individual firewall rule
model FirewallRule {
  id           String       @id @default(uuid())
  tenantId     String      
  propertyId   String      
  zoneId       String      
  chain        String?      @default("input") // nullable for auto-resolve mode; input, forward, output, prerouting, postrouting
  protocol     String? // tcp, udp, icmp, or null for all
  sourceIp     String?
  sourceMac    String?      // Source MAC address filter (ether saddr)
  sourcePort   String?      // String to support ranges like "8000-9000"
  sourcePortType String?   // 'include' or 'exclude'
  destIp       String?
  destPort     String?      // String to support ranges like "8000-9000"
  destPortType String?      // 'include' or 'exclude'
  action       String       @default("accept") // accept, drop, reject, log, jump, proxy, dnat, snat, masquerade, mark
  jumpTarget   String? // For jump action
  logPrefix    String?
  proxyTo      String?      // Proxy address:port for DNAT redirect
  sourceIpType     String?  @default("ip")    // Auto-detected: 'ip', 'cidr', 'domain'
  destIpType       String?  @default("ip")    // Auto-detected: 'ip', 'cidr', 'domain'
  sourceIpResolved String?                 // JSON array of resolved IPs when type=domain
  destIpResolved   String?                 // JSON array of resolved IPs when type=domain
  name              String   @default("Unnamed Rule")
  enabled      Boolean      @default(true)
  comment      String?
  priority     Int          @default(0)
  scheduleId       String?            
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  firewallZone     FirewallZone        @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  firewallSchedule FirewallSchedule?   @relation(fields: [scheduleId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([zoneId])
  @@index([enabled])
  @@index([priority])
}

/// FirewallSchedule - Time-based rule activation
model FirewallSchedule {
  id         String   @id @default(uuid())
  tenantId   String  
  propertyId String  
  name       String
  daysOfWeek String   @default("1,2,3,4,5,6,7") // Comma-separated: 1=Mon, 7=Sun
  startTime  String   @default("00:00")
  endTime    String   @default("23:59")
  timezone   String   @default("UTC")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  rules      FirewallRule[]

  @@index([tenantId])
  @@index([propertyId])
}

