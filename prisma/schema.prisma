  tenantId        String   
  referrerId      String   
  refereeId       String?  
  referralCode    String
  referralSource  String    @default("link") // link, email, qr, social
  rewardType      String    @default("points") // points, credit, discount, free_night
  rewardAmount    Float     @default(0)
  status          String    @default("pending") // pending, converted, rewarded, expired
  convertedAt     DateTime?
  rewardedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, referralCode])
  @@index([tenantId])
  @@index([referrerId])
  @@index([status])
}

/// GuestCommunicationTimeline - Tracks all guest communications
model GuestCommunicationTimeline {
  id              String    @id @default(uuid())
  tenantId        String   
  guestId         String   
  bookingId       String?  
  channel         String    // email, sms, whatsapp, in_app, phone, push
  direction       String    // inbound, outbound
  subject         String?
  content         String
  status          String    @default("sent") // draft, sent, delivered, read, failed, bounced
  sentBy          String?  
  sentAt          DateTime  @default(now())
  readAt          DateTime?
  metadata        String    @default("{}") // JSON: {templateId, automationId, campaignId}
  createdAt       DateTime  @default(now())
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([bookingId])
  @@index([channel])
  @@index([sentAt])
}

// ============================================================
// REVENUE MANAGEMENT MODULE - Advanced Analytics & Optimization
// ============================================================

/// LosPricingTier - Graduated Length-of-Stay pricing tiers
model LosPricingTier {
  id               String    @id @default(uuid())
  tenantId         String   
  propertyId       String   
  roomTypeId       String   
  minNights        Int
  maxNights        Int?      // null means unlimited upper bound
  label            String    // e.g. "1-2 nights", "3-5 nights"
  discountPercent  Float     @default(0) // 0%, 5%, 10%, etc.
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, roomTypeId, minNights])
  @@index([tenantId])
  @@index([propertyId])
  @@index([roomTypeId])
  @@index([isActive])
}

/// PricingSchedulerLog - Auto-apply pricing scheduler execution log
model PricingSchedulerLog {
  id                 String    @id @default(uuid())
  tenantId           String   
  propertyId         String
  status             String    @default("running") // running, completed, failed
  rulesEvaluated     Int       @default(0)
  rulesApplied       Int       @default(0)
  rulesSkipped       Int       @default(0)
  totalRevenueImpact Float     @default(0)
  errorDetails       String?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([startedAt])
}

// ============================================================
// OTA CHANNEL MANAGER - Content & Message Management
// ============================================================

/// OTAContentProfile - Per-channel content sync profiles
model OTAContentProfile {
  id            String     @id @default(uuid())
  tenantId      String    
  propertyId    String    
  channelName   String
  syncStatus    String     @default("pending") // synced, pending, failed, partial
  fieldMapping  String     @default("{}") // JSON: Record<string, string>
  lastSyncAt    DateTime? 
  totalFields   Int        @default(0)
  syncedFields  Int        @default(0)
  failedFields  Int        @default(0)
  errorDetails  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, propertyId, channelName])
  @@index([tenantId])
  @@index([propertyId])
  @@index([channelName])
  @@index([syncStatus])
}

/// OTAContentSyncLog - Content sync execution history
model OTAContentSyncLog {
  id            String     @id @default(uuid())
  tenantId      String    
  propertyId    String    
  channelName   String
  contentType   String     // photos, descriptions, amenities, policies, all
  syncType      String     @default("full") // full, partial
  status        String     @default("pending") // pending, processing, synced, failed, partial
  totalItems    Int        @default(0)
  syncedItems   Int        @default(0)
  failedItems   Int        @default(0)
  errorDetails  String?
  startedAt     DateTime   @default(now())
  completedAt   DateTime? 
  createdAt     DateTime   @default(now())
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([channelName])
  @@index([status])
  @@index([startedAt])
}

/// OTAMessage - Guest messages from OTA channels
model OTAMessage {
  id              String     @id @default(uuid())
  tenantId        String    
  propertyId      String    
  channelName     String
  reservationId   String    
  guestName       String
  subject         String
  body            String
  direction       String     @default("inbound") // inbound, outbound
  status          String     @default("unread") // unread, read, replied, archived
  priority        String     @default("normal") // normal, high, urgent
  guestEmail      String?
  guestPhone      String?
  bookingRef      String?
  channelMessageId String?
  receivedAt      DateTime   @default(now())
  repliedAt       DateTime? 
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([channelName])
  @@index([reservationId])
  @@index([status])
  @@index([direction])
  @@index([priority])
  @@index([receivedAt])
}

// ============================================================
// REVENUE MANAGEMENT - Auto-Overbooking & Last-Minute Triggers
// ============================================================

/// OverbookingSlot - Tracks virtual overbooking allocations per room type / date
model OverbookingSlot {
  id              String    @id @default(uuid())
  tenantId        String   
  propertyId      String   
  roomTypeId      String   
  date            DateTime 
  maxExtraRooms   Int       @default(0)   // maximum overbookable rooms for this date
  usedSlots       Int       @default(0)   // currently consumed overbooking slots
  confidence      Float     @default(0)   // confidence score from cancellation predictor
  status          String    @default("active") // active, absorbed, expired
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, roomTypeId, date])
  @@index([tenantId])
  @@index([propertyId])
  @@index([roomTypeId])
  @@index([date])
  @@index([status])
}

/// OverbookingConfig - Per-property overbooking configuration
model OverbookingConfig {
  id                String   @id @default(uuid())
  tenantId          String  
  propertyId        String  
  enabled           Boolean  @default(false)
  maxOverbookPercent Float   @default(5)
  minCancellationRisk Float  @default(0.15)
  allowedRoomTypes  String   @default("[]") // JSON: [roomTypeId, ...]
  upgradePaths      String   @default("[]") // JSON: [{fromRoomTypeId, toRoomTypeId}, ...]
  blacklistDates    String   @default("[]") // JSON: ["2024-12-25", ...]
  bufferDays        Int      @default(1) // stop overbooking N days before check-in
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId])
  @@index([tenantId])
  @@index([propertyId])
}

/// OverbookingLog - Execution log for overbooking calculations
model OverbookingLog {
  id              String    @id @default(uuid())
  tenantId        String   
  propertyId      String   
  date            DateTime 
  roomTypeId      String   
  action          String    // created, updated, absorbed
  details         String    @default("{}") // JSON: {maxExtra, confidence, bookingsAnalyzed}
  performedBy     String?  
  createdAt       DateTime  @default(now())
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([date])
  @@index([roomTypeId])
}

/// LastMinuteTrigger - Configurable last-minute pricing/inventory automation
model LastMinuteTrigger {
  id                        String   @id @default(uuid())
  tenantId                  String  
  propertyId                String  
  name                      String
  enabled                   Boolean  @default(true)
  triggerHoursBeforeCheckin Int      @default(48) // 48, 24, 12, 6, 3
  action                    String   @default("decrease_rate") // increase_rate, decrease_rate, send_offer, release_inventory
  value                     Float    @default(0) // percentage for rate changes
  minOccupancy              Int      @default(0)
  maxOccupancy              Int      @default(100)
  channelScope              String   @default("all") // all, direct_only, ota_only
  roomTypeIds               String   @default("[]") // JSON: [roomTypeId, ...]
  repeatOnDays              String   @default("0,1,2,3,4,5,6") // JSON: [0-6]
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
}

/// LastMinuteTriggerLog - Tracks when last-minute triggers fired (dedup)
model LastMinuteTriggerLog {
  id                String   @id @default(uuid())
  tenantId          String  
  propertyId        String  
  triggerId         String  
  roomTypeId        String  
  date              DateTime
  action            String
  value             Float
  bookingId         String? 
  result            String   @default("{}") // JSON: {newRate, oldRate, channel, ...}
  createdAt         DateTime @default(now())
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([triggerId, roomTypeId, date]) // one firing per trigger+room+date
  @@index([tenantId])
  @@index([propertyId])
  @@index([triggerId])
  @@index([date])
}
