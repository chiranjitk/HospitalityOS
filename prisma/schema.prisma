  propertyId      String  
  tenantId        String  

  // Display settings
  hotelName       String   @default("StaySuite")
  welcomeMessage  String   @default("Welcome! Please select an option below.")
  primaryColor    String   @default("#10b981")  // emerald
  logoUrl         String?
  backgroundStyle String   @default("gradient")  // gradient, solid, image

  // Timeout settings
