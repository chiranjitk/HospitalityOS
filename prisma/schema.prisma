/// FraudDetectionRule - Configurable fraud detection rules per tenant
model FraudDetectionRule {
  id          String   @id @default(uuid())
  tenantId    String  
  name        String
  description String?
  isEnabled   Boolean  @default(true)
  ruleType    String   // velocity, amount, geolocation, pattern, device_fingerprint
  conditions  String   // JSON - rule conditions
  action      String   @default("flag") // flag, block, review, mfa_required
  severity    String   @default("medium") // low, medium, high, critical
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alerts      FraudAlert[]

  @@index([tenantId, isEnabled])
}

/// FraudAlert - Alert generated when fraud is detected
model FraudAlert {
  id            String     @id @default(uuid())
  tenantId      String    
  paymentId     String?   
  userId        String?   
  ruleId        String?   
  alertType     String     // velocity_exceeded, amount_anomaly, pattern_match, etc.
  severity      String     // low, medium, high, critical
  status        String     @default("open") // open, reviewed, dismissed, confirmed_fraud
  riskScore     Int        // 0-100
  details       String     // JSON - alert details
  reviewedBy    String?   
  reviewedAt    DateTime? 
  resolution    String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  payment       Payment?              @relation(fields: [paymentId], references: [id])
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rule          FraudDetectionRule?   @relation(fields: [ruleId], references: [id])
  reviewer      User?                 @relation("FraudAlertReviewer", fields: [reviewedBy], references: [id])

  @@index([tenantId, status])
  @@index([paymentId])
  @@index([createdAt])
}

