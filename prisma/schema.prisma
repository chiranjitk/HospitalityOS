  username    String
  fromPlanId  String   
  toPlanId    String   
  amount      Float
  currency    String    @default("INR")
  folioId     String?   // If charged to room
  paymentStatus String  @default("pending") // pending, completed, failed, refunded
  coaStatus   String?   // pending, applied, failed
  activatedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([bookingId])
  @@index([sessionId])
  @@index([paymentStatus])
  @@index([createdAt])
}

/// WiFi Satisfaction Survey (F12) — In-portal guest feedback
model WiFiSatisfactionSurvey {
  id          String    @id @default(uuid())
  tenantId    String   
  propertyId  String?  
  guestId     String?  
  sessionId   String?   // Radius session ID
  rating      Int       // 1-5 stars
  comment     String?
  categories  String?   @default("{}") // JSON: { speed: 4, coverage: 3, easeOfConnect: 5 }
  deviceType  String?
  roomNumber  String?
  apName      String?
  ipAddress   String?
  guest       Guest?    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([guestId])
  @@index([rating])
  @@index([createdAt])
}

/// Pre-Arrival WiFi Credential Config (F7) — Settings per property
model WiFiPreArrivalConfig {
  id                    String    @id @default(uuid())
  tenantId              String   
  propertyId            String   
  enabled               Boolean   @default(false)
  hoursBeforeArrival    Int       @default(24) // 6, 12, 24, 48
  sendEmail             Boolean   @default(true)
  sendSms               Boolean   @default(true)
  emailTemplateId       String?  
  smsTemplate           String?   @default("Your WiFi at {{hotel_name}}: Network: {{ssid}}, Username: {{username}}, Password: {{password}}")
  includeQrCode         Boolean   @default(true)
  autoGenerateCreds     Boolean   @default(true) // Auto-create RADIUS user at booking confirmation
  planId                String?   // Default WiFi plan for guests
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property              Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, propertyId])
  @@index([tenantId])
}

/// WiFi SLA Configuration (F23) — SLA targets and metrics
model WiFiSLAConfig {
  id                  String    @id @default(uuid())
  tenantId            String   
  propertyId          String   
  uptimeTarget        Float     @default(99.9) // Percentage
  speedTargetDown     Float     @default(50)   // Mbps
  speedTargetUp       Float     @default(10)   // Mbps
  latencyTarget       Int       @default(20)   // ms
  measurementInterval Int       @default(5)    // Minutes
  alertOnBreach       Boolean   @default(true)
  breachDuration      Int       @default(15)   // Minutes before alert
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property            Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  metrics             WiFiSLAMetric[]

  @@unique([tenantId, propertyId])
  @@index([tenantId])
}

/// WiFi SLA Metric (F23) — Periodic measurement
model WiFiSLAMetric {
  id              String        @id @default(uuid())
  tenantId        String       
  propertyId      String       
  slaConfigId     String       
  periodStart     DateTime     
  periodEnd       DateTime     
  actualUptime    Float?        // Percentage
  avgSpeedDown    Float?        // Mbps
  avgSpeedUp      Float?        // Mbps
  avgLatency      Float?        // ms
  totalSessions   Int           @default(0)
  totalBandwidth  Float         @default(0) // GB
  breached        Boolean       @default(false)
  breachTypes     String?       @default("[]") // JSON array of breach types
  createdAt       DateTime      @default(now())
  slaConfig       WiFiSLAConfig @relation(fields: [slaConfigId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property        Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([slaConfigId])
  @@index([periodStart])
}

/// Portal Ad Campaign (F2) — Monetized WiFi portal ads
model PortalAdCampaign {
  id          String    @id @default(uuid())
  tenantId    String   
  propertyId  String?  
  name        String
  advertiser  String
  creativeUrl String    // Image or video URL
  creativeType String   @default("image") // image, video, html
  linkUrl     String?   // Click-through URL
  slot        String    @default("banner") // banner, interstitial, footer, sidebar
  priority    Int       @default(0)
  impressions Int       @default(0)
  clicks      Int       @default(0)
  revenue     Float     @default(0)
  status      String    @default("active") // draft, active, paused, completed
  startDate   DateTime 
  endDate     DateTime 
