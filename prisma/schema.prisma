/// WiFi Partner (F3) — Sponsored WiFi access partners
model WiFiPartner {
  id                String    @id @default(uuid())
  tenantId          String   
  name              String
  description       String?
  partnerType       String    @default("loyalty") // loyalty, airline, credit_card, corporate
  authMethod        String    @default("promo_code") // promo_code, auto_detect, deep_link
  costPerAuth       Float     @default(0)
  commission        Float     @default(0)
  maxDailyAuths     Int?
  activeAuths       Int       @default(0)
  totalAuths        Int       @default(0)
  totalRevenue      Float     @default(0)
  status            String    @default("active") // active, paused, inactive
