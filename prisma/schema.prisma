/// DhcpBlacklist - MAC deny list (dnsmasq: dhcp-host=<mac>,ignore)
model DhcpBlacklist {
  id         String      @id @default(uuid())
  tenantId   String     
  propertyId String     
  subnetId   String?     // null = global, applies to all subnets
  macAddress String // Supports wildcards: "aa:bb:cc:*:*:*"
  reason     String? // Why this MAC is blocked
  enabled    Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  dhcpSubnet DhcpSubnet? @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([subnetId])
  @@index([macAddress])
}

/// DhcpHostnameFilter - Block/ignore devices by hostname (dnsmasq: dhcp-ignore-names, dhcp-name-match)
model DhcpHostnameFilter {
  id          String      @id @default(uuid())
  tenantId    String     
  propertyId  String     
  subnetId    String?     // null = global
  pattern     String // Hostname pattern, supports trailing wildcard: "bad-device*"
  action      String      @default("ignore") // ignore (block name but allow lease), deny (block entirely)
  enabled     Boolean     @default(true)
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  dhcpSubnet  DhcpSubnet? @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([subnetId])
}

/// DhcpLease - Live DHCP lease state (synced from Kea, read-mostly)
model DhcpLease {
  id         String     @id @default(uuid())
  tenantId   String    
  propertyId String    
  subnetId   String    
  macAddress String
  ipAddress  String
  hostname   String?
  clientId   String?
  leaseStart DateTime   @default(now())
  leaseEnd   DateTime  
  state      String     @default("active") // active, expired, released, declined
  lastSeenAt DateTime   @default(now())
  subnet     DhcpSubnet @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([subnetId, ipAddress])
  @@index([tenantId])
  @@index([propertyId])
  @@index([macAddress])
  @@index([state])
  @@index([leaseEnd])
}

/// DhcpLeaseScript - Lease event hook scripts (dnsmasq: dhcp-script)
model DhcpLeaseScript {
  id          String   @id @default(uuid())
  tenantId    String  
  propertyId  String  
  name        String
  scriptPath  String // Absolute path to script, e.g. "/usr/local/bin/lease-event.sh"
  events      String   @default("[\"add\",\"del\",\"old\"]") // JSON: which events trigger the script
  enabled     Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, scriptPath])
  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
}

/// DhcpOption - Custom DHCP options (global and per-subnet)
model DhcpOption {
  id          String      @id @default(uuid())
  tenantId    String     
  propertyId  String     
  subnetId    String?     // null = global/property-level option
  code        Int // DHCP option code (e.g., 6=DNS, 42=NTP, 66=TFTP)
  name        String // Human-readable name
  value       String // Option value
  type        String      @default("string") // string, ip, integer, boolean, hex
  enabled     Boolean     @default(true)
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  dhcpSubnet  DhcpSubnet? @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([subnetId])
  @@index([code])
}

/// DhcpReservation - Static DHCP reservations (known MAC list)
model DhcpReservation {
  id          String     @id @default(uuid())
  tenantId    String    
  propertyId  String    
  subnetId    String    
  macAddress  String
  ipAddress   String
  hostname    String?
  leaseTime   Int? // Override default lease time
  linkedType  String? // guest, room, device, staff
  linkedId    String?    // Reference to guest/room/device
  description String?
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  dhcpSubnet  DhcpSubnet @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  property    Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([subnetId, macAddress])
  @@unique([subnetId, ipAddress])
  @@index([tenantId])
  @@index([propertyId])
  @@index([macAddress])
}

