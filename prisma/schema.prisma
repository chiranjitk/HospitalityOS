model HotelWebsite {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  propertyId      String   @db.Uuid
  domain          String   @unique
  customDomain    String?
  status          String   @default("draft") // draft, published, unpublished
  template        String   @default("modern") // modern, classic, boutique, resort, minimal
  theme           String   @default("{}") // JSON: primaryColor, secondaryColor, fontFamily, borderRadius, logoUrl, heroImageUrl
  pages           String   @default("[]") // JSON: HotelWebsitePage[]
  seo             String   @default("{}") // JSON: title, description, keywords, ogImage, faviconUrl
  analytics       String   @default("{}") // JSON: googleAnalyticsId, googleTagManagerId, facebookPixelId, etc.
  publishedHtml   String?  // Pre-rendered HTML for each page, JSON: { [pageSlug]: string }
  publishedAt     DateTime? @db.Timestamptz
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, propertyId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([domain])
}

