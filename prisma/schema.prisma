  id           String   @id @default(uuid())
  tenantId     String  
  propertyId   String  
  name         String
  protocol     String   @default("tcp") // tcp, udp, both
  externalPort Int
  internalIp   String
  internalPort Int
  sourceIp     String?  // Source IP restriction (CIDR) for DNAT rule
  interfaceId  String? 
  enabled      Boolean  @default(true)
