// ============================================================
// IP POOL MANAGEMENT MODULE
// ============================================================

/// IpPool - IP address pool for user restriction (IPAM)
/// Each pool defines a set of IP ranges. Pools can be assigned to WiFi plans
/// (plan level) and WiFi users (user override). Priority chain:
///   User override pool > Plan pool > Default pool > No restriction
model IpPool {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid
  propertyId    String?       @db.Uuid
  name          String
  description   String?
  gateway       String?       @db.Inet
  subnet        String?       @db.Inet // CIDR subnet e.g. 10.0.0.0/24
  isDefault     Boolean       @default(false) // Default pool if no pool assigned
  captivePortal Boolean       @default(false) // When true, subnet is written to /etc/restrictednetwork for default-deny + captive portal redirect
  enabled       Boolean       @default(true)
  createdAt     DateTime      @default(now()) @db.Timestamptz
  updatedAt     DateTime      @updatedAt @db.Timestamptz
  ranges        IpPoolRange[]
  plans         WiFiPlan[]
  users         WiFiUser[]    @relation("UserIpPoolOverride")
  planMappings  WiFiPlanIPPool[]
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([propertyId])
  @@index([isDefault])
  @@index([captivePortal])
}

/// IpPoolRange - Individual IP range within a pool
/// Uses PostgreSQL inet type for efficient range queries
model IpPoolRange {
  id        String   @id @default(uuid()) @db.Uuid
  poolId    String   @db.Uuid
  startIp   String   @db.Inet // Range start (inclusive)
  endIp     String   @db.Inet // Range end (inclusive)
  comment   String? // Optional label (e.g. "AP Floor 1", "Guest VLAN")
  createdAt DateTime @default(now()) @db.Timestamptz
  pool      IpPool   @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId])
}

/// WiFiPlanIPPool — Many-to-many junction table for Plan ↔ Pool mapping
/// A plan can have multiple IP pools. If a plan has mapped pools, the user's
/// IP must be in one of those pools. If a plan has NO mapped pools (and no
/// legacy ipPoolId), the IP must exist in ANY enabled pool.
model WiFiPlanIPPool {
  id        String   @id @default(uuid()) @db.Uuid
  planId    String   @db.Uuid
  poolId    String   @db.Uuid
  priority  Int      @default(0) // Lower = higher priority. Used for Framed-Route selection.
  createdAt DateTime @default(now()) @db.Timestamptz

  plan      WiFiPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  pool      IpPool   @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([planId, poolId])
  @@index([planId])
  @@index([poolId])
}

model WiFiPlan {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @db.Uuid
  name          String
  description   String?
  downloadSpeed Int
  uploadSpeed   Int
  burstDownloadSpeed Int?   // Burst ceil download (Mbps). null/0 = no burst (ceil = rate)
  burstUploadSpeed   Int?   // Burst ceil upload (Mbps). null/0 = no burst (ceil = rate)
  dataLimit          Int?
  sessionLimit       Int?
  sessionTimeoutSec  Int?
  idleTimeoutSec     Int?
  maxDevices         Int               @default(1)
  fupPolicyId   String?           @db.Uuid
  ipPoolId      String?           @db.Uuid
  price         Float             @default(0)
  currency      String            @default("USD")
  billingModel  String            @default("flat")    // flat, usage, tiered, hybrid
  includedDataMb Int              @default(0)          // Included data in flat/hybrid plans
  pricePerMb    Float             @default(0)          // Per-MB overage rate (for usage/tiered/hybrid)
  priority      Int               @default(0)
  validityDays   Int               @default(1)
  validityMinutes Int              @default(1440) // Fine-grained validity (minutes). Used when set; validityDays kept for backward compat.
  status        String            @default("active")
  createdAt     DateTime          @default(now()) @db.Timestamptz
  updatedAt     DateTime          @updatedAt @db.Timestamptz
  aaaaConfigs   WiFiAAAConfig[]
  fupPolicy     FairAccessPolicy? @relation(fields: [fupPolicyId], references: [id])
  ipPool        IpPool?           @relation(fields: [ipPoolId], references: [id])
  planPools     WiFiPlanIPPool[]
  roomTypes     RoomType[]        @relation("RoomTypeWiFiPlan")
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions      WiFiSession[]
  wifiUsers          WiFiUser[]
  wifiInvoiceLines   WiFiInvoiceLine[]
  vouchers           WiFiVoucher[]
  ldapConfigs        RadiusLDAPConfig[]

  @@index([tenantId])
  @@index([ipPoolId])
}

model WiFiSession {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  planId       String?   @db.Uuid
  guestId      String?   @db.Uuid
  bookingId    String?   @db.Uuid
  username     String?
  acctUniqueId String?
  macAddress   String
  ipAddress    String?
  deviceName   String?
  deviceType   String?
  startTime    DateTime  @default(now()) @db.Timestamptz
  endTime      DateTime? @db.Timestamptz
  dataUsed     BigInt    @default(0)
  duration     Int       @default(0)
  authMethod   String    @default("voucher")
  status       String    @default("active")
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  plan         WiFiPlan? @relation(fields: [planId], references: [id])
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([macAddress])
  @@index([guestId])
  @@index([username])
  @@index([acctUniqueId])
}

model WiFiUser {
  id               String     @id @default(uuid()) @db.Uuid
  tenantId         String     @db.Uuid
  propertyId       String     @db.Uuid
  username         String     @unique
  password         String
  guestId          String?    @db.Uuid
  bookingId        String?    @db.Uuid
  userType         String     @default("guest")
  planId           String?    @db.Uuid
  ipPoolId         String?    @db.Uuid
  validFrom        DateTime   @db.Timestamptz
  validUntil       DateTime   @db.Timestamptz
  maxSessions      Int        @default(1)
  sessionCount     Int        @default(0)
  totalBytesIn     BigInt     @default(0)
  totalBytesOut    BigInt     @default(0)
  status           String     @default("active")
  radiusSynced     Boolean    @default(false)
  radiusSyncedAt   DateTime?  @db.Timestamptz
  lastAccountingAt DateTime?  @db.Timestamptz
  createdAt        DateTime   @default(now()) @db.Timestamptz
  updatedAt        DateTime   @updatedAt @db.Timestamptz
  radCheck         RadCheck[]
  radReply         RadReply[]
  deviceProfiles   DeviceProfile[]
  plan             WiFiPlan?  @relation(fields: [planId], references: [id])
  ipPool           IpPool?    @relation("UserIpPoolOverride", fields: [ipPoolId], references: [id])
  property           Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wifiInvoiceLines   WiFiInvoiceLine[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([username])
  @@index([guestId])
  @@index([bookingId])
  @@index([status])
  @@index([ipPoolId])
}

/// WiFiInvoiceLine — Granular billing line items for WiFi charges
/// Tracks plan fees, data overage, bandwidth upgrades, and topups.
/// Auto-posted to guest folios during the daily billing run.
model WiFiInvoiceLine {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  propertyId      String?   @db.Uuid
  guestId         String?   @db.Uuid
  bookingId       String?   @db.Uuid
  folioLineItemId String?   @unique @db.Uuid
  wifiUserId      String?   @db.Uuid
  sessionId       String?
  periodStart     DateTime  @db.Timestamptz
  periodEnd       DateTime  @db.Timestamptz
  chargeType      String                          // plan_fee, data_overage, bandwidth_upgrade, topup
  description     String
  quantity        Float     @default(1)
  unitPrice       Float
  totalAmount     Float
  currency        String    @default("USD")
  dataUsedMb      Float     @default(0)
  planId          String?   @db.Uuid
  status          String    @default("pending")  // pending, posted, invoiced, voided
  postedToFolioAt DateTime? @db.Timestamptz
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @updatedAt @db.Timestamptz

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property       Property?        @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  guest          Guest?           @relation(fields: [guestId], references: [id], onDelete: SetNull)
  booking        Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  wifiUser       WiFiUser?        @relation(fields: [wifiUserId], references: [id], onDelete: SetNull)
  plan           WiFiPlan?        @relation(fields: [planId], references: [id], onDelete: SetNull)
  folioLineItem  FolioLineItem?   @relation(fields: [folioLineItemId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([guestId])
  @@index([bookingId])
  @@index([wifiUserId])
  @@index([status])
  @@index([chargeType])
  @@index([periodStart, periodEnd])
