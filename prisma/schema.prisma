// ============================================================
// 7. PACKAGE PLANS / RATE BUNDLING MODULE
// ============================================================

model PackagePlan {
  id               String   @id @default(uuid())
  tenantId         String  
  propertyId       String  
  name             String
  description      String?
  baseRoomTypeId   String  
  roomRateInclusive Boolean  @default(false)
  startDate        DateTime
  endDate          DateTime
  minNights        Int      @default(1)
  maxNights        Int?
  totalBasePrice   Float    @default(0)
  currency         String   @default("USD")
  sortOrder        Int      @default(0)
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  components       PackageComponent[]
  rates            PackageRate[]
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([sortOrder])
}

model PackageComponent {
  id               String      @id @default(uuid())
  packagePlanId    String     
  componentType    String      // meal, experience, spa, airport_transfer, minibar, laundry, late_checkout, early_checkin, other
  referenceId      String?    
  referenceName    String?
  includedQty      Int         @default(1)
  unitCost         Float       @default(0)
  isIncluded       Boolean     @default(true) // true = included in package, false = addon
  sortOrder        Int         @default(0)
  createdAt        DateTime    @default(now())
  packagePlan      PackagePlan @relation(fields: [packagePlanId], references: [id], onDelete: Cascade)

  @@index([packagePlanId])
  @@index([componentType])
  @@index([sortOrder])
}

model PackageRate {
  id             String       @id @default(uuid())
  tenantId       String      
  propertyId     String      
  packagePlanId  String      
  roomTypeId     String      
  startDate      DateTime    
  endDate        DateTime    
  price          Float        @default(0)
  currency       String       @default("USD")
  minStay        Int          @default(1)
  maxStay        Int?
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  packagePlan    PackagePlan  @relation(fields: [packagePlanId], references: [id], onDelete: Cascade)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([packagePlanId, roomTypeId, startDate])
  @@index([tenantId])
  @@index([propertyId])
  @@index([packagePlanId])
  @@index([roomTypeId])
  @@index([startDate, endDate])
  @@index([status])
}

