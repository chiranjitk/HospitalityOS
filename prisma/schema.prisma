// ============================================================
// WIFI FEATURE SUGGESTIONS — NEW MODELS
// ============================================================

/// WiFi Health Alert (F21) — Automatic alerts when WiFi quality degrades
model WiFiAlert {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  propertyId  String?   @db.Uuid
  type        String    // ap_down, latency, capacity, auth_failure, radius_error, bandwidth_exhaustion, nas_offline
  severity    String    @default("warning") // critical, warning, info
  title       String
  message     String
  source      String?   // NAS identifier, AP MAC, etc.
  metadata    String?   @default("{}") // JSON: extra context (signal strength, client count, etc.)
  status      String    @default("active") // active, acknowledged, resolved
  acknowledgedBy String? @db.Uuid
  acknowledgedAt DateTime? @db.Timestamptz
  resolvedAt  DateTime? @db.Timestamptz
  resolvedBy  String?   @db.Uuid
  resolveNote String?
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
}

/// WiFi Health Alert Configuration — Thresholds and settings for alert generation
/// One config per tenant (global), with optional per-property overrides.
model WiFiAlertConfig {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @db.Uuid
  propertyId          String?   @db.Uuid // null = tenant-level defaults
  latencyWarningMs    Int       @default(200) // Latency threshold for warning (ms)
  latencyCriticalMs   Int       @default(500) // Latency threshold for critical (ms)
  enabled             Boolean   @default(true) // Master switch for this config
  createdAt           DateTime  @default(now()) @db.Timestamptz
  updatedAt           DateTime  @updatedAt @db.Timestamptz
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property            Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, propertyId])
  @@index([tenantId])
  @@index([propertyId])
}

/// Multi-Device Registration (F9) — Track guest devices for auto-authentication
model WiFiDevice {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  guestId     String    @db.Uuid
  propertyId  String?   @db.Uuid
  macAddress  String
  deviceName  String?
  deviceType  String?   // phone, laptop, tablet, watch, tv, other
  userAgent   String?
  ipAddress   String?
  isApproved  Boolean   @default(true)
  firstSeen   DateTime  @default(now()) @db.Timestamptz
  lastSeen    DateTime  @default(now()) @db.Timestamptz
  autoAuth    Boolean   @default(true) // Auto-authenticate this device
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  guest       Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, macAddress])
  @@index([tenantId])
  @@index([guestId])
  @@index([macAddress])
  @@index([lastSeen])
}

/// GDPR/Privacy Consent Log (F13) — Mandatory consent before WiFi access
model WiFiConsentLog {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  guestId         String?   @db.Uuid
  propertyId      String?   @db.Uuid
  sessionId       String?   // Radius session ID
  consentType     String    @default("wifi_access") // wifi_access, marketing, data_processing
  consentTextHash String    // SHA256 hash of consent text shown
  ipAddress       String
  macAddress      String?
  userAgent       String?
  optInMarketing  Boolean   @default(false)
  dataRetentionDays Int     @default(90)
  expiresAt       DateTime  @db.Timestamptz
  createdAt       DateTime  @default(now()) @db.Timestamptz
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property        Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([sessionId])
  @@index([ipAddress])
  @@index([createdAt])
}

/// Identity Verification Log (F14) — KYC for regulatory compliance
model WiFiIdentityLog {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @db.Uuid
  propertyId         String?   @db.Uuid
  sessionId          String?   // Radius session ID
  username           String
  verificationMethod String    // none, room_number, otp_sms, otp_email, government_id, selfie_verify
  verifiedIdentity   String?   // Room number, masked phone/email, ID number, etc.
  verificationStatus String    @default("pending") // pending, verified, failed, skipped
  ipAddress          String
  macAddress         String?
  countryCode        String?   // ID issuing country
  idType             String?   // aadhaar, passport, national_id, driving_license
  failureReason      String?
  verifiedAt         DateTime? @db.Timestamptz
  createdAt          DateTime  @default(now()) @db.Timestamptz
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property           Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([username])
  @@index([sessionId])
  @@index([verificationMethod])
  @@index([verificationStatus])
  @@index([createdAt])
}

/// WiFi OTP — Pending OTP codes for guest verification (F14)
model WiFiOTP {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  propertyId  String?   @db.Uuid
  sessionId   String?
  username    String?
  destination String    // Phone number or email address
  channel     String    // sms, email
  codeHash    String    // SHA-256 hash of the OTP code
  otpLength   Int       @default(6)
  expiresAt   DateTime  @db.Timestamptz
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  status      String    @default("pending") // pending, verified, expired, failed
  ipAddress   String?
  verifiedAt  DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([destination])
  @@index([sessionId])
  @@index([status])
  @@index([expiresAt])
}

/// WiFi Heatmap Data (F17) — AP signal strength readings for coverage visualization
model WiFiHeatmapReading {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @db.Uuid
  propertyId     String        @db.Uuid
  floorPlanId    String?       @db.Uuid
  apName         String
  apMac          String?
  apX            Float         // X position on floor plan (0-100%)
  apY            Float         // Y position on floor plan (0-100%)
  signalStrength Int           // RSSI in dBm (typically -30 to -90)
  clientCount    Int           @default(0)
  band           String        @default("2.4") // 2.4, 5, 6
  channel        Int?
  frequency      Int?          // MHz
  noiseFloor     Int?          // dBm
  snr            Int?          // Signal to Noise Ratio
  recordedAt     DateTime      @default(now()) @db.Timestamptz
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property       Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  floorPlan      WiFiFloorPlan? @relation(fields: [floorPlanId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@index([floorPlanId])
  @@index([apName])
  @@index([recordedAt])
}

/// WiFi Heatmap Floor Plan Config (F17)
model WiFiFloorPlan {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  propertyId  String    @db.Uuid
  floorName   String
  floorNumber Int       @default(1)
  svgData     String    // SVG content of the floor plan
  width       Int       @default(800)
  height      Int       @default(600)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  readings    WiFiHeatmapReading[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, floorNumber])
  @@index([tenantId])
  @@index([propertyId])
}

/// System Alert Rules — Threshold-based monitoring rules for system/WiFi metrics
/// Persists alert configuration across restarts. Checked every 2s via the health metrics poll.
/// Bound to a property so operators know which physical hardware box the alert applies to.
model SystemAlertRule {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  propertyId    String?   @db.Uuid // Property where the hardware box is installed (null = tenant-level)
  metric        String    // cpu, memory, disk, interface_rx, interface_tx, active_sessions, auth_reject_rate, radius_health
  operator      String    // >, <, >=, <=
  threshold     Float
  interfaceName String?   // Required when metric = interface_rx or interface_tx
  enabled       Boolean   @default(true)
  label         String
  cooldownSec   Int       @default(300) // seconds between re-alerting for the same rule
  notifyEmail   Boolean   @default(true)  // send email when this rule fires
  notifySms     Boolean   @default(false) // send SMS when this rule fires (opt-in for critical alerts)
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
  events        SystemAlertEvent[]
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, metric, operator, threshold, interfaceName])
  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
}

/// System Alert Events — Triggered alert instances with lifecycle (active → acknowledged → resolved)
model SystemAlertEvent {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  propertyId      String?   @db.Uuid // Copied from rule — which property's hardware triggered this
  ruleId          String    @db.Uuid
  metric          String
  operator        String
  threshold       Float
  interfaceName   String?   // Copied from rule — which network interface
  value           Float
  status          String    @default("active") // active, acknowledged, resolved
  triggeredAt     DateTime  @default(now()) @db.Timestamptz
  resolvedAt      DateTime? @db.Timestamptz
  acknowledgedBy  String?   @db.Uuid
  acknowledgedAt  DateTime? @db.Timestamptz
  rule            SystemAlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([propertyId])
  @@index([ruleId])
  @@index([triggeredAt])
}

