  tenantId    String   
  partnerId   String   
  guestId     String?  
  sessionId   String?
  username    String
  partnerRef  String?   // Loyalty number, promo code, etc.
  partnerTier String?
  costToPartner Float   @default(0)
  commission  Float     @default(0)
  ipAddress   String?
  guest       Guest?    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  partner     WiFiPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([partnerId])
  @@index([sessionId])
  @@index([createdAt])
}

/// WiFi Settings — Tenant-level feature configuration (device mgmt, consent, identity, bandwidth)
model WiFiSettings {
  id          String    @id @default(uuid())
  tenantId    String   
  propertyId  String?  
  key         String
  value       String    @default("{}") // JSON string
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, propertyId, key])
  @@index([tenantId])
  @@index([tenantId, key])
}

model WorkOrder {
