/// StaticRoute - Persistent static routes (default + custom)
model StaticRoute {
  id            String   @id @default(uuid())
  tenantId      String  
  propertyId    String  
  name          String
  destination   String // 0.0.0.0/0 for default, or 10.0.0.0/24 etc
  gateway       String // 192.168.1.1
  metric        Int      @default(100)
  interfaceName String? // eth0, bond0, etc.
  protocol      String   @default("static") // static, dhcp, kernel
  isDefault     Boolean  @default(false)
  enabled       Boolean  @default(true)
  description   String?
