/// RoomVlan - Room-per-VLAN isolation mapping
/// Assigns a dedicated VLAN to each hotel room for Layer 2 guest isolation.
/// Feature-gated behind 'room_vlan_isolation' feature flag.
model RoomVlan {
  id                String           @id @default(uuid())
  tenantId          String          
  propertyId        String          
  roomNumber        String                                // "101", "302", "Suite-Penthouse"
  vlanId            Int                                   // 1101, 1302
  subnet            String           @default("10.1.0.0/28") // Room's IP subnet
  gateway           String           @default("10.1.0.1")    // VLAN gateway
  parentInterfaceId String?                        // Trunk interface (eth1, bridge0, etc.)
  role              String           @default("guest")       // wan, lan, dmz, management, wifi, guest, iot, unused
  mtu               Int              @default(1500)
  floor             Int              @default(1)
  roomType          String           @default("standard")    // standard, suite, conference, vip
  bandwidthPlanId   String?                        // Link to BandwidthPolicy
  status            String           @default("active")      // active, maintenance, disabled, reserved
  description       String?
  firewallRulesGenerated Boolean     @default(false)         // Whether nftables chains were pushed
  lastProvisionedAt    DateTime?    
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  property          Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentInterface   NetworkInterface? @relation(fields: [parentInterfaceId], references: [id], onDelete: SetNull)
  bandwidthPolicy   BandwidthPolicy? @relation(fields: [bandwidthPlanId], references: [id])

  @@unique([propertyId, roomNumber])
  @@unique([propertyId, vlanId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([vlanId])
  @@index([status])
  @@index([floor])
  @@index([parentInterfaceId])
}

