/// InterfaceConfig - IP configuration per interface
model InterfaceConfig {
  id           String   @id @default(uuid())
  tenantId     String  
  propertyId   String  
  interfaceId  String  
  mode         String   @default("static") // static, dhcp, disabled
  ipAddress    String?
