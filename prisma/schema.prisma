  name         String
  url          String
  events       String               @default("[]")
  secret       String
  isActive     Boolean              @default(true)
  totalCalls   Int                  @default(0)
  failedCalls  Int                  @default(0)
  lastCalledAt DateTime?           
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deliveryLogs WebhookDeliveryLog[]
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model WiFiAAAConfig {
  id                        String    @id @default(uuid())
  tenantId                  String   
  propertyId                String    @unique
  defaultPlanId             String?  
  defaultDownloadSpeed      Int       @default(10)
  defaultUploadSpeed        Int       @default(10)
  defaultSessionLimit       Int?
  defaultDataLimit          Int?
  autoProvisionOnCheckin    Boolean   @default(true)
  autoDeprovisionOnCheckout Boolean   @default(true)
  autoDeprovisionDelay      Int       @default(0)
  authMethod                String    @default("pap")
  allowMacAuth              Boolean   @default(false)
  accountingSyncInterval    Int       @default(5)
  lastSyncAt                DateTime?
  lastSyncId                String?  
  maxConcurrentSessions     Int       @default(3)
  sessionTimeoutPolicy      String    @default("hard")
  portalEnabled             Boolean   @default(true)
  portalTitle               String?
  portalLogo                String?
  portalTerms               String?
  portalRedirectUrl         String?
  portalBrandColor          String    @default("#0d9488")
  voucherPortalUrl          String? // Base URL for voucher QR codes (e.g. https://wifi.hotel.com/connect)
  usernameFormat            String    @default("room_random") // room_random | room_only | lastname_room | firstinitial_lastname | lastname_firstinitial | mobile | email_prefix | booking_id | custom_prefix | passport
  usernamePrefix            String? // Custom prefix for custom_prefix format
  usernameCase              String    @default("lowercase") // lowercase | uppercase | as_is
  usernameMinLength         Int       @default(4)
  usernameMaxLength         Int       @default(32)
  passwordFormat            String    @default("random_alphanumeric") // random_alphanumeric | random_numeric | room_number | last4_mobile | lastname | lastname_room | fixed | checkin_date | passport
  passwordFixedValue        String? // Fixed password for fixed format
  passwordLength            Int       @default(8) // Length for random formats
  passwordIncludeUppercase  Boolean   @default(true)
  passwordIncludeNumbers    Boolean   @default(true)
  passwordIncludeSymbols    Boolean   @default(false)
  credentialSeparator       String    @default("_") // Separator between parts (e.g. "_" or "")
  credentialPrintOnVoucher  Boolean   @default(true)
  credentialShowInPortal    Boolean   @default(true)
  duplicateUsernameAction   String    @default("append_random") // append_random | reject | overwrite
  status                    String    @default("active")
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  defaultPlan               WiFiPlan? @relation(fields: [defaultPlanId], references: [id])
  property                  Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant                    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model WiFiAccountingSync {
  id               String   @id @default(uuid())
  lastRadAcctId    String
  lastSyncedAt     DateTime @default(now())
  recordsProcessed Int      @default(0)
  errors           Int      @default(0)
  lastError        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WiFiGateway {
  id                   String    @id @default(uuid())
  tenantId             String   
  propertyId           String   
  name                 String
  description          String?
  ipAddress            String
  macAddress           String?
  vendor               String
  model                String?
  version              String?
  radiusSecret         String
  radiusAuthPort       Int       @default(1812)
  radiusAcctPort       Int       @default(1813)
  coaEnabled           Boolean   @default(false)
  coaPort              Int       @default(3799)
  coaSecret            String?
  captivePortalEnabled Boolean   @default(false)
  captivePortalUrl     String?
  splashPageId         String?  
  defaultVlan          Int?
  guestVlan            Int?
  staffVlan            Int?
  managementUrl        String?
