  autoPosted         Boolean      @default(false)
  createdAt          DateTime     @default(now())
  rule               PostingRule  @relation(fields: [ruleId], references: [id])
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
