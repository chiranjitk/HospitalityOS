model RatePlan {
  id                 String           @id @default(uuid())
  tenantId           String          
  roomTypeId         String          
  name               String
  code               String
  description        String?
  basePrice          Float
  currency           String           @default("USD")
  mealPlan           String           @default("room_only")
  minStay            Int              @default(1)
  maxStay            Int?
  advanceBookingDays Int?
  cancellationPolicy String?
  cancellationHours  Int?
  bookingStartDays   Int?
  bookingEndDays     Int?
  promoCode          String?
  discountPercent    Float?
  discountAmount     Float?
  promoStart         DateTime?       
  promoEnd           DateTime?       
  status             String           @default("active")
  // Derivation chain fields
  derivedFromId      String?         
  derivationType     String?                           // 'percentage' | 'fixed'
  derivationValue    Float?                             // e.g. -15 for -15%, or -20 for -$20
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?       
