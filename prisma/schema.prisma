generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// SaaS Tenant - Each hotel/hotel chain is a tenant

model AdCampaign {
  id               String          @id @default(uuid())
  tenantId         String         
  propertyId       String?        
  name             String
  description      String?
  type             String          @default("search") // search, display, metasearch, social
  platform         String          @default("google") // google, meta, tripadvisor, trivago
  status           String          @default("draft") // draft, active, paused, completed, archived
  budget           Float           @default(0)
  budgetType       String          @default("daily") // daily, lifetime
  spentAmount      Float           @default(0)
  currency         String          @default("USD")
  startDate        DateTime?      
  endDate          DateTime?      
  bidStrategy      String          @default("auto") // auto, manual, enhanced
  bidAmount        Float?
  targetCpa        Float? // Target cost per acquisition
  targetRoas       Float? // Target return on ad spend
  targeting        String          @default("{}") // JSON: locations, devices, audiences
  keywords         String          @default("[]") // JSON array of keywords
  negativeKeywords String          @default("[]")
  roomTypes        String          @default("[]") // JSON array of room type IDs
  ratePlans        String          @default("[]") // JSON array of rate plan IDs
  impressions      Int             @default(0)
  clicks           Int             @default(0)
  conversions      Int             @default(0)
  revenue          Float           @default(0)
  ctr              Float           @default(0)
  cpc              Float           @default(0)
  conversionRate   Float           @default(0)
  roas             Float           @default(0)
  externalId       String?         // External platform campaign ID
  externalData     String          @default("{}") // Sync data from platform
  lastSyncAt       DateTime?      
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  performance      AdPerformance[]

  @@index([tenantId])
  @@index([status])
  @@index([platform])
  @@index([type])
}

model AdPerformance {
  id              String     @id @default(uuid())
  campaignId      String    
  date            DateTime  
  impressions     Int        @default(0)
  clicks          Int        @default(0)
  conversions     Int        @default(0)
  cost            Float      @default(0)
  revenue         Float      @default(0)
  ctr             Float      @default(0)
  cpc             Float      @default(0)
  cpa             Float      @default(0)
  roas            Float      @default(0)
  conversionRate  Float      @default(0)
  avgPosition     Float?
  qualityScore    Float?
  searchImpShare  Float?
  deviceBreakdown String     @default("{}") // JSON: mobile, desktop, tablet
  sourceBreakdown String     @default("{}") // JSON: google, bing, etc.
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  campaign        AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

model AISuggestion {
  id               String    @id @default(uuid())
  tenantId         String   
  type             String
  title            String
  description      String?
  impact           String    @default("medium")
  potentialRevenue Float     @default(0)
  confidence       Float     @default(0.8)
  status           String    @default("pending")
  data             String    @default("{}")
  appliedAt        DateTime?
  dismissedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([status])
}

model Amenity {
  id        String   @id @default(uuid())
  tenantId  String  
  name      String
  icon      String? // Lucide icon name
  category  String   @default("general") // general, bathroom, room, view, services
  isDefault Boolean  @default(false) // System default amenities
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([category])
}

model Asset {
  id                      String    @id @default(uuid())
  tenantId                String   
  propertyId              String   
  name                    String
  category                String
  description             String?
  roomId                  String?  
  location                String?
  purchasePrice           Float?
  purchaseDate            DateTime?
  currentValue            Float?
  warrantyExpiry          DateTime?
  warrantyProvider        String?
  lastMaintenanceAt       DateTime?
  nextMaintenanceAt       DateTime?
  maintenanceIntervalDays Int?
  status                  String    @default("active")
  serialNumber            String?
  modelNumber             String?
  manufacturer            String?
  conditionScore          Int? // 1-10 condition rating
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property                Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room                    Room?     @relation(fields: [roomId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomId])
  @@index([category])
  @@index([status])
}

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String  
  userId        String? 
  module        String
  action        String
  entityType    String
  entityId      String? 
  oldValue      String?
  newValue      String?
  ipAddress     String?
  userAgent     String?
  correlationId String? 
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
}

model AiConversation {
  id          String              @id @default(uuid())
  tenantId    String             
  userId      String             
  title       String
  messages    AiConversationMessage[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model AiConversationMessage {
  id             String          @id @default(uuid())
  conversationId String         
  role           String
  content        String
  createdAt      DateTime        @default(now())
  conversation   AiConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model AutomationExecutionLog {
  id            String         @id @default(uuid())
  ruleId        String        
  triggerData   String?
  status        String
  errorMessage  String?
  actionsResult String?
  executedAt    DateTime       @default(now())
  rule          AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([executedAt])
}

model AutomationRule {
  id                String                   @id @default(uuid())
  tenantId          String                  
  name              String
  description       String?
  triggerEvent      String
  triggerConditions String?
  actions           String
  isActive          Boolean                  @default(true)
  executionCount    Int                      @default(0)
  lastExecutedAt    DateTime?               
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  executionLogs     AutomationExecutionLog[]
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([triggerEvent])
}

/// BandwidthPolicy - BW shaping policy linked to WiFi plans
model BandwidthPolicy {
  id                String   @id @default(uuid())
  tenantId          String  
  propertyId        String  
  name              String
  downloadKbps      Int      @default(10240) // 10 Mbps default
  uploadKbps        Int      @default(10240)
  burstDownloadKbps Int?
  burstUploadKbps   Int?
  priority          Int      @default(5) // 0=highest, 10=lowest
  planId            String?  // Link to WiFiPlan
  description       String?
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomVlans         RoomVlan[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([planId])
  @@index([enabled])
}

model BandwidthPolicyDetail {
  id                    String   @id @default(uuid())
  tenantId              String  
  bandwidthPolicyId     String  
  scheduleAccessId      String? 
  downloadLimitBps      Int      @default(0)
  uploadLimitBps        Int      @default(0)
  guaranteedDownBps     Int      @default(0)
  guaranteedUpBps       Int      @default(0)
  burstTimeSeconds      Int      @default(0)
  burstThresholdBytes   Int      @default(0)
  burstUpTimeSeconds    Int      @default(0)
  burstUpThresholdBytes Int      @default(0)
  contentionRatio       Int      @default(1)
  priority              Int      @default(0)
  isEnabled             Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bandwidthPolicyId])
  @@index([scheduleAccessId])
  @@index([isEnabled])
}

/// BandwidthPool - Shared bandwidth pool per subnet
/// Pool class is a container (HTB parent) for all users in that subnet.
/// NOT a bandwidth limit itself — user leaf classes do the real limiting.
/// Min 100 Mbps, Max 10 Gbit (same as root class).
/// If total of all pools exceeds root (10Gbit), HTB shares bandwidth proportionally.
model BandwidthPool {
  id                  String   @id @default(uuid())
  tenantId            String  
  propertyId          String? 
  name                String
  subnet              String?
  vlanId              Int?
  totalDownloadKbps   Int      @default(2000000) // Pool container: default 2Gbit, max 10Gbit
  totalUploadKbps     Int      @default(2000000) // Pool container: default 2Gbit, max 10Gbit
  perUserDownloadKbps Int?                          // Default per-user download limit (if no plan assigned)
  perUserUploadKbps   Int?                          // Default per-user upload limit (if no plan assigned)
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  property            Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([vlanId])
  @@index([enabled])
}

/// BandwidthTopup - Purchasable bandwidth topup packages (Accsium tblfapbandwidthtopup)
model BandwidthTopup {
  id                 String   @id @default(uuid())
  tenantId           String  
  propertyId         String  
  name               String
  description        String?
  allottedUploadMb   Float    @default(0)
  allottedDownloadMb Float    @default(0)
  allottedTotalMb    Float    @default(0)
  applicableType     String   @default("total")
  bandwidthPolicyId  String? 
  price              Float    @default(0)
  currency           String   @default("USD")
  validityMinutes    Int      @default(60)
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  property           Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([tenantId])
  @@index([enabled])
}

/// BandwidthUsageDaily - Daily aggregate bandwidth stats
model BandwidthUsageDaily {
  id              String   @id @default(uuid())
  tenantId        String  
  propertyId      String  
  date            DateTime
  totalDownloadMb Float    @default(0)
  totalUploadMb   Float    @default(0)
  uniqueUsers     Int      @default(0)
  peakUsers       Int      @default(0)
  peakTime        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
  @@index([tenantId])
  @@index([propertyId])
  @@index([date])
}

/// BandwidthUsageSession - Per-session bandwidth tracking
model BandwidthUsageSession {
  id              String    @id @default(uuid())
  tenantId        String   
  propertyId      String   
  sessionId       String   
  username        String?
  ipAddress       String
  macAddress      String?
  planId          String?  
  policyId        String?  
  downloadBytes   Int       @default(0)
  uploadBytes     Int       @default(0)
  durationSeconds Int       @default(0)
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([sessionId])
  @@index([ipAddress])
  @@index([startedAt])
  @@index([endedAt])
}

model BankAccount {
  id                String            @id @default(uuid())
  tenantId          String           
  propertyId        String?          
  accountName       String
  accountNumber     String // Masked or encrypted
  bankName          String
  bankCode          String? // IFSC, SWIFT, Routing number, etc.
  accountType       String            @default("checking") // checking, savings, money_market
  currency          String            @default("USD")
  openingBalance    Float             @default(0)
  currentBalance    Float             @default(0)
  lastReconciledAt  DateTime?        
  lastStatementDate DateTime?        
  status            String            @default("active") // active, closed, frozen
  isDefault         Boolean           @default(false)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?        
  transactions      BankTransaction[]
  reconciliations   Reconciliation[]
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankName])
  @@index([status])
}

model BankTransaction {
  id              String           @id @default(uuid())
  tenantId        String          
  bankAccountId   String          
  transactionDate DateTime        
  valueDate       DateTime?        // Value date (may differ from transaction date)
  transactionType String // debit, credit
  amount          Float
  currency        String           @default("USD")
  balance         Float? // Balance after transaction
  description     String?
  reference       String? // Bank reference number
  chequeNumber    String?
  payeeName       String?
  payeeAccount    String?
  category        String? // User-defined category
  subCategory     String?
  isReconciled    Boolean          @default(false)
  reconciledAt    DateTime?       
  importSource    String           @default("manual") // manual, csv, api, ofx
  importBatchId   String?          // Batch ID for bulk imports
  rawLine         String? // Original line from import
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?       
  bankAccount     BankAccount      @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reconciliations Reconciliation[]
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([isReconciled])
  @@index([transactionType])
  @@index([importBatchId])
}

/// BondConfig - Link aggregation / bonding configuration
model BondConfig {
  id            String       @id @default(uuid())
  tenantId      String      
  propertyId    String      
  name          String // bond0
  mode          String       @default("active-backup") // active-backup, balance-rr, balance-xor, 802.3ad, balance-tlb, balance-alb
  miimon        Int          @default(100)
  lacpRate      String       @default("slow")
  primaryMember String?
  enabled       Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  property      Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members       BondMember[]

  @@unique([propertyId, name])
  @@index([tenantId])
  @@index([propertyId])
}

/// BondMember - Individual interface in a bond
model BondMember {
  id               String           @id @default(uuid())
  bondConfigId     String          
  interfaceId      String          
  priority         Int              @default(0)
  createdAt        DateTime         @default(now())
  bondConfig       BondConfig       @relation(fields: [bondConfigId], references: [id], onDelete: Cascade)
  networkInterface NetworkInterface @relation(fields: [interfaceId], references: [id], onDelete: Cascade)

  @@unique([bondConfigId, interfaceId])
  @@index([bondConfigId])
}

model Booking {
  id                  String            @id @default(uuid())
  tenantId            String           
  propertyId          String           
  confirmationCode    String            @unique
  externalRef         String?
  primaryGuestId      String           
  roomId              String?          
  roomTypeId          String           
  checkIn             DateTime         
  checkOut            DateTime         
  adults              Int               @default(1)
  children            Int               @default(0)
  infants             Int               @default(0)
  roomRate            Float             @default(0)
  taxes               Float             @default(0)
  fees                Float             @default(0)
  discount            Float             @default(0)
  totalAmount         Float             @default(0)
  currency            String            @default("USD")
  ratePlanId          String?          
  promoCode           String?
  source              String            @default("direct")
  channelId           String?          
  status              String            @default("draft")
  actualCheckIn       DateTime?        
  actualCheckOut      DateTime?        
  checkedInBy         String?
  checkedOutBy        String?
  cancelledAt         DateTime?        
  cancelledBy         String?
  cancellationReason  String?
  specialRequests     String?
  notes               String?
  internalNotes       String?
  groupId             String?          
  isGroupLeader       Boolean           @default(false)
  guaranteeType       String            @default("none") // none, credit_card, deposit, corporate, travel_agent, guarantee_letter
  guaranteeReference  String?
  guaranteeCardToken  String?
  depositRequired     Boolean           @default(false)
  depositAmount       Float             @default(0)
  depositDeadline     DateTime?        
  depositPaid         Boolean           @default(false)
  cancellationRisk    Float?            // ML-predicted cancellation risk 0-1
  preArrivalSent      Boolean           @default(false)
  preArrivalCompleted Boolean           @default(false)
  preArrivalLink      String?
  preArrivalExpires   DateTime?        
  kycRequired         Boolean           @default(false)
  kycCompleted        Boolean           @default(false)
  kycStatus           String            @default("pending")
  portalToken         String?           @unique
  portalTokenExpires  DateTime?        
  eSignature          String?
  eSignedAt           DateTime?        
  preferences         String            @default("{}")
  idempotencyKey      String?           @unique
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?        
  primaryGuest        Guest             @relation(fields: [primaryGuestId], references: [id])
  roomType            RoomType          @relation(fields: [roomTypeId], references: [id])
  room                Room?             @relation(fields: [roomId], references: [id])
  property            Property          @relation(fields: [propertyId], references: [id])
  ratePlan            RatePlan?         @relation(fields: [ratePlanId], references: [id])
  group               GroupBooking?     @relation(fields: [groupId], references: [id])
  auditLogs           BookingAuditLog[]
  folios              Folio[]
  guestStays          GuestStay[]
  waitlist               WaitlistEntry?
  scheduledCharges        ScheduledCharge[]
  cancellationPenalties   CancellationPenalty[]
  commissions              CommissionRecord[]
  laundryOrders            LaundryOrder[]
  minibarConsumptions      MinibarConsumption[]
  depositSchedules         DepositSchedule[]
  earlyCheckoutRequests    EarlyCheckoutRequest[]
  earlyCheckinRequests     EarlyCheckinRequest[]
  lateCheckoutRequests     LateCheckoutRequest[]

  checkInDate              DateTime?           
  checkOutDate             DateTime?           

  @@index([tenantId])
  @@index([propertyId])
  @@index([primaryGuestId])
  @@index([status])
  @@index([checkIn])
  @@index([checkOut])
  @@index([groupId])
  @@index([tenantId, propertyId, status])
  @@index([tenantId, checkIn])
  @@index([tenantId, checkOut])
}

/// EarlyCheckoutRequest - Tracks guest requests for early checkout
model EarlyCheckoutRequest {
  id                String    @id @default(uuid())
  bookingId         String   
  tenantId          String   
  propertyId        String   
  guestId           String   
  requestedDate     DateTime 
  originalCheckOut  DateTime 
  reason            String?
  status            String    @default("pending") // pending, approved, rejected, completed
  reviewedBy        String?  
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  booking           Booking   @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([tenantId, status])
  @@index([guestId])
}

model BookingAuditLog {
  id          String   @id @default(uuid())
  bookingId   String  
  action      String
  oldStatus   String?
  newStatus   String?
  notes       String?
  performedBy String?
  performedAt DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model Brand {
  id             String     @id @default(uuid())
  tenantId       String    
  name           String
  code           String     @unique
  description    String?
  logo           String?
  primaryColor   String?
  secondaryColor String?
  standards      String     @default("{}")
  status         String     @default("active")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  properties     Property[]

  @@index([tenantId])
}

/// BridgeConfig - Network bridge configuration
model BridgeConfig {
  id               String   @id @default(uuid())
  tenantId         String  
  propertyId       String  
  name             String // br0, br-guest
  memberInterfaces String   @default("[]") // JSON: ["eth1","eth2"]
  stpEnabled       Boolean  @default(false)
  forwardDelay     Int      @default(15)
  helloTime        Int      @default(2)
  maxAge           Int      @default(20)
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, name])
  @@index([tenantId])
  @@index([propertyId])
}

model Camera {
  id             String          @id @default(uuid())
  propertyId     String         
  groupId        String?        
  name           String
  location       String?
  streamUrl      String?
  streamType     String          @default("rtsp")
  isRecording    Boolean         @default(false)
  recordingUrl   String?
  status         String          @default("online")
  posX           Int?
  posY           Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  group          CameraGroup?    @relation(fields: [groupId], references: [id])
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  events         CameraEvent[]
  securityEvents SecurityEvent[]

  @@index([propertyId])
}

model CameraEvent {
  id             String    @id @default(uuid())
  tenantId       String   
  cameraId       String   
  type           String
  timestamp      DateTime  @default(now())
  thumbnailUrl   String?
  clipUrl        String?
  description    String?
  confidence     Float?
  isAlert        Boolean   @default(false)
  alertType      String?
  acknowledgedBy String?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())
  camera         Camera    @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cameraId])
  @@index([timestamp])
}

model CameraGroup {
  id          String   @id @default(uuid())
  propertyId  String  
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cameras     Camera[]
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Campaign {
  id                String            @id @default(uuid())
  tenantId          String           
  name              String
  description       String?
  type              String
  subject           String?
  content           String
  templateId        String?          
  targetSegments    String            @default("[]")
  scheduledAt       DateTime?        
  sentAt            DateTime?        
  totalRecipients   Int               @default(0)
  sentCount         Int               @default(0)
  openedCount       Int               @default(0)
  clickedCount      Int               @default(0)
  bouncedCount      Int               @default(0)
  unsubscribedCount Int               @default(0)
  status            String            @default("draft")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
