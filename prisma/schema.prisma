// ============================================================
// ALLOTMENT RELEASE MODULE - Cutoff schedules for channel allotments
// ============================================================

/// AllotmentReleaseRule - Defines when unsold allotment rooms are released back to the general pool
model AllotmentReleaseRule {
  id              String   @id @default(uuid())
  tenantId        String  
  propertyId      String? 
  connectionId    String? 
  channelCode     String
  roomTypeId      String? 
  releaseType     String   @default("graduated") // graduated, fixed, percentage
  releaseSchedule String    // JSON: [{daysBefore: 30, releasePercent: 20}, {daysBefore: 14, releasePercent: 50}, {daysBefore: 7, releasePercent: 100}]
  releaseAllDays  Int      @default(7) // For fixed type: release all N days before
  releasePercentPerDay Int @default(10) // For percentage type: release X% per day
  startReleaseFrom DateTime?
  endReleaseAt    DateTime?
  minAllotment    Int      @default(0) // Never release below this number
  autoRelease     Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([tenantId, connectionId, channelCode, isActive])
  @@index([roomTypeId])
}

/// AllotmentReleaseLog - Records of release actions
model AllotmentReleaseLog {
  id              String   @id @default(uuid())
  tenantId        String  
  ruleId          String  
  connectionId    String  
  channelCode     String
  roomTypeId      String? 
  date            DateTime
  roomsReleased   Int      @default(0)
  roomsBefore     Int      @default(0)
  roomsAfter      Int      @default(0)
  releaseType     String
  daysBeforeArrival Int
  triggeredBy     String   @default("auto") // auto, manual
  createdAt       DateTime @default(now())
  @@index([tenantId, ruleId, date])
  @@index([connectionId])
}

// ============================================================
// LICENSING MODULE - Per-module entitlements & usage tracking
// ============================================================

/// LicenseModuleEntitlement - Per-addon module limits per tenant
/// Each add-on module (gateway, pos, crm, etc.) has its own limit dimension.
/// The base PMS module uses Tenant.maxRooms (room count).
/// The gateway module uses concurrentActiveUsers (enforced at auth time).
model LicenseModuleEntitlement {
  id                   String    @id @default(uuid())
  tenantId             String   
  moduleKey            String                            // Feature flag key: wifi, pos, crm, etc.
  moduleName           String                            // Display name: "WiFi & Network", "Restaurant & POS"
  limitType            String                            // concurrent_users, rooms, users, properties, staff, devices, bookings, data_mb
  limitValue           Int       @default(0)              // 0 = unlimited
  currentUsage         Int       @default(0)              // Real-time usage (updated by enforcement)
  peakUsage            Int       @default(0)              // Peak usage (all-time high for this billing period)
  warningThreshold     Float     @default(0.8)            // Warning at 80% usage by default
  hardLimit            Boolean   @default(true)           // true = block when exceeded, false = warn only
  billingDimension     String?                            // e.g., "per_room", "per_user", "flat" for pricing
  pricePerUnit         Float?                             // Price per unit above base (if overage applies)
  isValid              Boolean   @default(true)           // false when license revoked/expired
  effectiveFrom        DateTime  @default(now())
  effectiveTo          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usageLogs            LicenseUsageLog[]

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
  @@index([moduleKey])
  @@index([isValid])
}

/// LicenseUsageLog - Periodic usage snapshots for trend analysis & billing
model LicenseUsageLog {
  id              String    @id @default(uuid())
  tenantId        String   
  entitlementId   String   
  moduleKey       String
  usageValue      Int       @default(0)
  limitValue      Int       @default(0)
  usagePercent    Float     @default(0)           // usageValue/limitValue * 100
  sampledAt       DateTime  @default(now())
  createdAt       DateTime  @default(now())
  entitlement     LicenseModuleEntitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)

  @@index([tenantId, moduleKey])
  @@index([entitlementId])
  @@index([sampledAt])
}


/// IpWhitelistRule - IP whitelist/blacklist rules for tenant access control
model IpWhitelistRule {
  id          String   @id @default(uuid())
  tenantId    String  
  type        String   @default("whitelist") // whitelist, blacklist
  ipAddress   String   // Single IP or CIDR range (e.g., "192.168.1.0/24", "10.0.0.5")
  description String?
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String? 
  creator     User?    @relation(fields: [createdBy], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, isEnabled])
  @@index([ipAddress])
}


