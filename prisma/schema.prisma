/// DhcpSubnet - DHCP subnet configuration
model DhcpSubnet {
  id              String               @id @default(uuid()) @db.Uuid
  tenantId        String               @db.Uuid
  propertyId      String               @db.Uuid
  name            String
  subnet          String // 192.168.1.0/24
  gateway         String? // 192.168.1.1
  poolStart       String // 192.168.1.100
  poolEnd         String // 192.168.1.254
  leaseTime       Int                  @default(3600) // seconds
  vlanId          Int?
  vlanConfigId    String?              @db.Uuid
  domainName      String?
  dnsServers      String               @default("[]") // JSON: ["8.8.8.8","1.1.1.1"]
  ntpServers      String               @default("[]") // JSON: ["pool.ntp.org"]
  bootFileName    String?
  nextServer      String?
  ipv6Enabled     Boolean              @default(false) // Feature flag: enable DHCPv6 dual-stack
  ipv6Prefix      String? // e.g. "fd00::/64"
  ipv6PoolStart   String? // e.g. "fd00::100"
  ipv6PoolEnd     String? // e.g. "fd00::200"
  ipv6LeaseTime   Int                  @default(3600) // seconds, same default as IPv4
  ipv6RAType      String               @default("slaac") // slaac, stateful, ra-only, ra-stateless
  enabled         Boolean              @default(true)
  description     String?
  createdAt       DateTime             @default(now()) @db.Timestamptz
  updatedAt       DateTime             @updatedAt @db.Timestamptz
  vlanConfig      VlanConfig?          @relation(fields: [vlanConfigId], references: [id])
  property        Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations    DhcpReservation[]
  leases          DhcpLease[]
  dhcpOptions     DhcpOption[]
  blacklists      DhcpBlacklist[]
  tagRules        DhcpTagRule[]
  hostnameFilters DhcpHostnameFilter[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([subnet])
  @@index([enabled])
}

