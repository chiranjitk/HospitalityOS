/// SyslogServer - External syslog forwarding configuration
model SyslogServer {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  propertyId  String   @db.Uuid
  name        String
  protocol    String   @default("udp") // udp, tcp, tls
