/// HardwareAdapter - Registered hardware provider configuration per property
model HardwareAdapter {
  id             String   @id @default(uuid())
  tenantId       String  
  propertyId     String  
  providerId     String   // "simulator", "assa-abloy-visionline", "salto-ks", "dormakaba-saflok", "nuki", "seam", "stripe-terminal", "square-terminal", "adyen-terminal", "verifone-engage", "ingenico"
  category       String   @default("lock") // "lock" | "terminal"
  displayName    String
  config         String   @default("{}") // JSON: HardwareAdapterConfig
  credentials    String   @default("{}") // JSON: HardwareAdapterCredentials (encrypted at rest)
  enabled        Boolean  @default(true)
  healthStatus   String   @default("unknown") // unknown, healthy, degraded, unhealthy, disconnected
  lastHealthyAt  DateTime?
  lastCheckedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, providerId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([providerId])
  @@index([category])
  @@index([enabled])
}

/// HardwareOperationLog - Audit trail for all hardware adapter operations
model HardwareOperationLog {
  id              String   @id @default(uuid())
  tenantId        String  
  propertyId      String  
  adapterId       String? 
  providerId      String
  category        String   // "lock" | "terminal"
  operation       String   // e.g., "connect", "issue_key", "create_checkout"
  targetId        String?  // internal lock/terminal ID
  vendorTargetId  String?  // vendor-specific lock/terminal ID
  success         Boolean
  errorCode       String?
  errorMessage    String?
  initiatedBy     String?  // userId or "system"
  requestJson     String?  // sanitized JSON
  responseJson    String?
  durationMs      Int?
  correlationId   String? 
