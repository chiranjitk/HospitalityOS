/// CaptivePortal - Portal instance configuration
model CaptivePortal {
  id                String                 @id @default(uuid())
  tenantId          String                
  propertyId        String                
  name              String
  description       String?
  listenIp          String                 @default("0.0.0.0")
  listenPort        Int                    @default(80)
  useSsl            Boolean                @default(false)
  sslCertPath       String?
  sslKeyPath        String?
  enabled           Boolean                @default(true)
  isDefault         Boolean                @default(false) // Fallback portal when no IP subnet match
  autoAuthEnabled   Boolean                @default(true)  // Enable/disable silent auto-reauth for returning devices
  maxConcurrent     Int                    @default(1000)
  sessionTimeout    Int                    @default(86400)
  idleTimeout       Int                    @default(3600)
  redirectUrl       String?
  successMessage    String?
  failMessage       String?
  // Zone-based portal routing (standalone gateway mode)
  slug              String                 @unique @default("default-zone") // URL path: /lobby, /pool, /club
  roamingMode       String                 @default("auth_origin") // auth_origin | seamless | reauth
  allowsRoamingFrom String                 @default("[]") // JSON array of slugs: ["lobby"]
  authMethod        String                 @default("voucher") // voucher | room_number | pms_credentials | sms_otp | social | mac_auth | open_access
  maxBandwidthDown  Int                    @default(5242880) // bytes/sec (5Mbps)
  maxBandwidthUp    Int                    @default(1048576) // bytes/sec (1Mbps)
  bandwidthPolicy   String                 @default("zone") // zone | origin | minimum (when roaming)
  nasIdentifier     String                 @default("") // auto or manual: "staysuite-pool-v20"
  ssidList          String                 @default("[]") // JSON array: ["PoolWiFi", "Hotel_Pool"]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  property          Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vlanConfigs       VlanConfig[]
  portalMappings    PortalMapping[]
  authMethods       PortalAuthentication[]
  portalPages       PortalPage[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
}

