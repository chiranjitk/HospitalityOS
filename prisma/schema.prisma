// ============================================================
// IP POOL MANAGEMENT MODULE
// ============================================================

/// IpPool - IP address pool for user restriction (IPAM)
/// Each pool defines a set of IP ranges. Pools can be assigned to WiFi plans
/// (plan level) and WiFi users (user override). Priority chain:
///   User override pool > Plan pool > Default pool > No restriction
model IpPool {
  id            String        @id @default(uuid())
  tenantId      String       
  propertyId    String?      
  name          String
  description   String?
  gateway       String?       
  subnet        String?        // CIDR subnet e.g. 10.0.0.0/24
  isDefault     Boolean       @default(false) // Default pool if no pool assigned
  captivePortal Boolean       @default(false) // When true, subnet is written to /etc/restrictednetwork for default-deny + captive portal redirect
  enabled       Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ranges        IpPoolRange[]
  plans         WiFiPlan[]
  users         WiFiUser[]    @relation("UserIpPoolOverride")
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([propertyId])
  @@index([isDefault])
  @@index([captivePortal])
}

/// IpPoolRange - Individual IP range within a pool
/// Uses PostgreSQL inet type for efficient range queries
model IpPoolRange {
  id        String   @id @default(uuid())
  poolId    String  
  startIp   String    // Range start (inclusive)
  endIp     String    // Range end (inclusive)
  comment   String? // Optional label (e.g. "AP Floor 1", "Guest VLAN")
  createdAt DateTime @default(now())
  pool      IpPool   @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@index([poolId])
}

model WiFiPlan {
  id            String            @id @default(uuid())
  tenantId      String           
  name          String
  description   String?
  downloadSpeed Int
  uploadSpeed   Int
  burstDownloadSpeed Int?   // Burst ceil download (Mbps). null/0 = no burst (ceil = rate)
  burstUploadSpeed   Int?   // Burst ceil upload (Mbps). null/0 = no burst (ceil = rate)
  dataLimit          Int?
  sessionLimit       Int?
  sessionTimeoutSec  Int?
  idleTimeoutSec     Int?
  maxDevices         Int               @default(1)
  fupPolicyId   String?          
  ipPoolId      String?          
  price         Float             @default(0)
  currency      String            @default("USD")
  priority      Int               @default(0)
  validityDays   Int               @default(1)
  validityMinutes Int              @default(1440) // Fine-grained validity (minutes). Used when set; validityDays kept for backward compat.
  status        String            @default("active")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  aaaaConfigs   WiFiAAAConfig[]
  fupPolicy     FairAccessPolicy? @relation(fields: [fupPolicyId], references: [id])
  ipPool        IpPool?           @relation(fields: [ipPoolId], references: [id])
  roomTypes     RoomType[]        @relation("RoomTypeWiFiPlan")
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions      WiFiSession[]
  wifiUsers     WiFiUser[]
  vouchers      WiFiVoucher[]

  @@index([tenantId])
  @@index([ipPoolId])
}

model WiFiSession {
  id           String    @id @default(uuid())
  tenantId     String   
  planId       String?  
  guestId      String?  
  bookingId    String?  
  username     String?
  acctUniqueId String?
  macAddress   String
  ipAddress    String?
  deviceName   String?
  deviceType   String?
  startTime    DateTime  @default(now())
  endTime      DateTime?
  dataUsed     BigInt    @default(0)
  duration     Int       @default(0)
  authMethod   String    @default("voucher")
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  plan         WiFiPlan? @relation(fields: [planId], references: [id])
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([macAddress])
  @@index([guestId])
  @@index([username])
  @@index([acctUniqueId])
}

model WiFiUser {
  id               String     @id @default(uuid())
  tenantId         String    
  propertyId       String    
  username         String     @unique
  password         String
  guestId          String?   
  bookingId        String?   
  userType         String     @default("guest")
  planId           String?   
  ipPoolId         String?   
  validFrom        DateTime  
  validUntil       DateTime  
  maxSessions      Int        @default(1)
  sessionCount     Int        @default(0)
  totalBytesIn     BigInt     @default(0)
  totalBytesOut    BigInt     @default(0)
  status           String     @default("active")
  radiusSynced     Boolean    @default(false)
  radiusSyncedAt   DateTime? 
  lastAccountingAt DateTime? 
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  radCheck         RadCheck[]
  radReply         RadReply[]
  deviceProfiles   DeviceProfile[]
  plan             WiFiPlan?  @relation(fields: [planId], references: [id])
  ipPool           IpPool?    @relation("UserIpPoolOverride", fields: [ipPoolId], references: [id])
  property         Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([username])
  @@index([guestId])
  @@index([bookingId])
  @@index([status])
  @@index([ipPoolId])
}

/// WiFiUserStatusHistory - User status change audit trail (Accsium tbluserstatushistory)
model WiFiUserStatusHistory {
  id           String   @id @default(uuid())
  tenantId     String  
  propertyId   String  
  username     String
  userId       String? 
  oldStatus    String?
  newStatus    String
  changedBy    String?
  changeReason String?
  ipAddress    String?
  createdAt    DateTime @default(now())
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([tenantId])
  @@index([username])
  @@index([userId])
  @@index([createdAt])
}

model WiFiVoucher {
  id         String    @id @default(uuid())
  tenantId   String   
  planId     String   
  code       String    @unique
  guestId    String?  
  bookingId  String?  
