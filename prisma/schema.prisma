  @@index([code])
}

// ============================================================
// WIFI FEATURE SUGGESTIONS — NEW MODELS
// ============================================================

/// WiFi Health Alert (F21) — Automatic alerts when WiFi quality degrades
model WiFiAlert {
  id          String    @id @default(uuid())
  tenantId    String   
  propertyId  String?  
  type        String    // ap_down, latency, capacity, auth_failure, radius_error, bandwidth_exhaustion, nas_offline
  severity    String    @default("warning") // critical, warning, info
  title       String
  message     String
  source      String?   // NAS identifier, AP MAC, etc.
  metadata    String?   @default("{}") // JSON: extra context (signal strength, client count, etc.)
  status      String    @default("active") // active, acknowledged, resolved
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolvedAt  DateTime?
  resolvedBy  String?  
  resolveNote String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
}

/// Multi-Device Registration (F9) — Track guest devices for auto-authentication
model WiFiDevice {
  id          String    @id @default(uuid())
  tenantId    String   
  guestId     String   
  propertyId  String?  
  macAddress  String
  deviceName  String?
  deviceType  String?   // phone, laptop, tablet, watch, tv, other
  userAgent   String?
  ipAddress   String?
  isApproved  Boolean   @default(true)
  firstSeen   DateTime  @default(now())
  lastSeen    DateTime  @default(now())
  autoAuth    Boolean   @default(true) // Auto-authenticate this device
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  guest       Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, macAddress])
  @@index([tenantId])
  @@index([guestId])
  @@index([macAddress])
  @@index([lastSeen])
}

/// GDPR/Privacy Consent Log (F13) — Mandatory consent before WiFi access
model WiFiConsentLog {
  id              String    @id @default(uuid())
  tenantId        String   
  guestId         String?  
  propertyId      String?  
  sessionId       String?   // Radius session ID
  consentType     String    @default("wifi_access") // wifi_access, marketing, data_processing
  consentTextHash String    // SHA256 hash of consent text shown
  ipAddress       String
  macAddress      String?
  userAgent       String?
  optInMarketing  Boolean   @default(false)
  dataRetentionDays Int     @default(90)
  expiresAt       DateTime 
  createdAt       DateTime  @default(now())
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property        Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([sessionId])
  @@index([ipAddress])
  @@index([createdAt])
}

/// Identity Verification Log (F14) — KYC for regulatory compliance
model WiFiIdentityLog {
  id                 String    @id @default(uuid())
  tenantId           String   
  propertyId         String?  
  sessionId          String?   // Radius session ID
  username           String
  verificationMethod String    // none, room_number, otp_sms, otp_email, government_id, selfie_verify
  verifiedIdentity   String?   // Room number, masked phone/email, ID number, etc.
  verificationStatus String    @default("pending") // pending, verified, failed, skipped
  ipAddress          String
  macAddress         String?
  countryCode        String?   // ID issuing country
  idType             String?   // aadhaar, passport, national_id, driving_license
  failureReason      String?
  verifiedAt         DateTime?
  createdAt          DateTime  @default(now())
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property           Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([username])
  @@index([sessionId])
  @@index([verificationMethod])
  @@index([verificationStatus])
  @@index([createdAt])
}

/// Bandwidth Upgrade Purchase (F1) — Guest upsell transactions
model WiFiBandwidthUpgrade {
