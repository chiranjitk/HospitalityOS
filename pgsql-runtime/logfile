	    IF v_plan_down IS NULL THEN RETURN v_up || 'K/' || v_down || 'K'; END IF;
	    IF v_down < v_plan_down * 1000 THEN
	        RETURN v_up || 'K/' || v_down || 'K';
	    ELSE
	        RETURN (v_up / 1000) || 'M/' || (v_down / 1000) || 'M';
	    END IF;
	END; $function$
