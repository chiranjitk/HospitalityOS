	    IF v_down < v_plan_down * 1000 THEN
	        RETURN v_down || 'K/' || v_up || 'K';
	    ELSE
	        RETURN (v_down / 1000) || 'M/' || (v_up / 1000) || 'M';
	    END IF;
	END; $function$
