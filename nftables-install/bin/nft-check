#!/bin/bash
# nft-check: Syntax checker for nftables rules files
# Separates SYNTAX errors from RUNTIME errors (no root needed)
#
# Usage:
#   nft-check -f rules.nft          Check a rules file
#   nft-check "add table inet x"   Check inline rules
#   nft-check --json -f rules.nft  Also show JSON output for valid rules
#
# Exit codes:
#   0 = valid syntax
#   1 = syntax error found
#   2 = file not found or usage error

NFT_BIN="/home/z/my-project/nftables-install/sbin/nft"
export LD_LIBRARY_PATH="/tmp/nft-deps/usr/lib/x86_64-linux-gnu:/home/z/my-project/nftables-install/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

if [ $# -eq 0 ]; then
    echo "Usage: nft-check [-f file | 'nft command']"
    echo "  nft-check -f rules.nft           Check ruleset file"
    echo "  nft-check 'add table inet foo'   Check inline command"
    exit 2
fi

FILE=""
INLINE=""
JSON_MODE=0

for arg in "$@"; do
    case "$arg" in
        --json|-j) JSON_MODE=1 ;;
        -f) FILE="$2"; shift ;;
        *.nft) FILE="$arg" ;;
        *) INLINE="$*" ;;
    esac
done

if [ -n "$FILE" ]; then
    if [ ! -f "$FILE" ]; then
        echo -e "${RED}Error: File not found: $FILE${NC}"
        exit 2
    fi
    INPUT_CMD="-f $FILE"
elif [ -n "$INLINE" ]; then
    echo "$INLINE" > /tmp/nft-check-input.nft
    INPUT_CMD="-f /tmp/nft-check-input.nft"
else
    echo "Usage: nft-check [-f file | 'nft command']"
    exit 2
fi

# Run nft inside user+net namespace, capture output
OUTPUT=$(unshare --user --map-root-user --net -- "$NFT_BIN" $INPUT_CMD 2>&1)
EXIT=$?

# Filter: syntax errors vs runtime errors
SYNTAX_ERRORS=$(echo "$OUTPUT" | grep -i "syntax error")
RUNTIME_ERRORS=$(echo "$OUTPUT" | grep -v -i "syntax error" | grep -i "error\|failed\|not permitted\|no such file")

if [ $EXIT -eq 0 ]; then
    echo -e "${GREEN}✓ SYNTAX VALID${NC} — All rules parsed successfully"
    if [ $JSON_MODE -eq 1 ]; then
        echo ""
        echo -e "${CYAN}── JSON Output ──${NC}"
        unshare --user --map-root-user --net -- "$NFT_BIN" -j list ruleset 2>/dev/null | python3 -m json.tool 2>/dev/null
    fi
    exit 0
elif [ -n "$SYNTAX_ERRORS" ]; then
    echo -e "${RED}✗ SYNTAX ERROR(S) FOUND${NC}"
    echo ""
    echo "$SYNTAX_ERRORS"
    echo ""
    echo -e "${YELLOW}── All errors (filtered): ──${NC}"
    echo "$OUTPUT" | grep -i "error"
    exit 1
else
    # No syntax errors but failed — these are runtime errors (missing modules, interfaces, etc.)
    echo -e "${GREEN}✓ SYNTAX VALID${NC} — Rules parsed successfully"
    if [ -n "$RUNTIME_ERRORS" ]; then
        echo -e "${YELLOW}⚠ Runtime warnings (non-fatal, need kernel modules):${NC}"
        echo "$RUNTIME_ERRORS" | head -10
    fi
    exit 0
fi
